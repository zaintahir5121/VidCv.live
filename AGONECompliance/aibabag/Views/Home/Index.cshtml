        grid-auto-flow: column;
        grid-auto-columns: minmax(190px, 240px);
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 6px;
    }

    .person-card,
    .memory-card {
        border-radius: 18px;
        border: 1px solid var(--line);
        background: #fcfdff;
        padding: 12px;
    }

    .person-photo {
        width: 48px;
        height: 48px;
        border-radius: 12px;
