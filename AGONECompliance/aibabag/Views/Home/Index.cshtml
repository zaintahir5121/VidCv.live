@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@{
    ViewData["Title"] = "AIBABAG";
    var isLocalMode = HostingEnvironment.IsDevelopment().ToString().ToLowerInvariant();
}

<div class="app-shell" id="appShell">
    <section class="hero-section" id="heroSection">
        <div class="hero-glow"></div>
        <p class="hero-kicker">AIBABAG</p>
        <h1>Discover your cosmic personality ✨</h1>
        <p class="hero-sub">
            Spotify Wrapped vibes, astrology humor, and playful cosmic energy in one beautiful scroll.
        </p>
        <div class="hero-actions">
            <button id="googleBtn" class="cta-btn primary">Continue with Google</button>
            <button id="guestBtn" class="cta-btn ghost">Try as Guest (Local / Dev)</button>
        </div>
        <p class="hero-note">Just for fun. No technical drama. No clutter.</p>
    </section>

    <main id="experience" class="hidden">
        <section class="panel welcome">
            <div class="avatar-wrap">
                <img id="avatarImage" class="avatar hidden" alt="Profile avatar" />
                <div id="avatarFallback" class="avatar-fallback"></div>
            </div>
            <div>
                <h2 id="welcomeTitle">Hey there 👋</h2>
                <p>The universe has thoughts about you.</p>
            </div>
            <button id="logoutBtn" class="tiny-btn hidden">Logout</button>
        </section>

        <section class="panel mood">
            <p class="section-tag">TODAY'S COSMIC MOOD</p>
            <h3 id="moodTitle">🌞 Radiant Energy</h3>
            <p id="moodLine">You look like the main character and the soundtrack at the same time.</p>
            <small>Just for fun. Not a biometric or medical reading.</small>
        </section>

        <section class="panel snapshot">
            <p class="section-tag">ASTRO SNAPSHOT</p>
            <div class="snapshot-grid" id="snapshotGrid"></div>
        </section>

        <section class="panel spirit">
            <p class="section-tag">SPIRIT ANIMAL</p>
            <h3 id="spiritAnimalTitle">🦊 Chill Fox</h3>
            <p id="spiritAnimalLine">Clever, observant, and pretending not to care.</p>
        </section>

        <section class="panel birthdays">
            <p class="section-tag">🎂 You share a birthday with legends</p>
            <div id="birthdayCards" class="horizontal-cards"></div>
        </section>

        <section class="panel personality">
            <p class="section-tag">PERSONALITY INSIGHTS</p>
            <div id="insightCards" class="insight-cards"></div>
        </section>

        <section class="panel share">
            <p class="section-tag">SHARE MOMENT</p>
            <div id="sharePreview" class="share-preview">
                I just discovered my cosmic personality ✨ <br />
                Aibabag
            </div>
            <div class="share-actions">
                <button id="shareImageBtn" class="cta-btn primary">Share image</button>
                <button id="copyLinkBtn" class="cta-btn ghost">Copy link</button>
                <button id="downloadBtn" class="cta-btn ghost">Download</button>
            </div>
            <div class="social-actions">
                <input id="facebookToken" placeholder="Facebook access token (optional)" />
                <input id="facebookPageId" placeholder="Facebook page ID (optional)" />
                <button id="facebookPostBtn" class="tiny-btn">Post to Facebook</button>
                <input id="linkedInToken" placeholder="LinkedIn access token (optional)" />
                <input id="linkedInUrn" placeholder="LinkedIn person URN (optional)" />
                <button id="linkedInPostBtn" class="tiny-btn">Post to LinkedIn</button>
                <p id="socialStatus" class="muted"></p>
            </div>
        </section>

        <section class="panel history">
            <p class="section-tag">COSMIC MEMORY LANE</p>
            <div id="historyCards" class="horizontal-cards"></div>
        </section>
    </main>
</div>

<div class="modal hidden" id="cameraModal">
    <div class="modal-card">
        <h3>Cosmic Mood Capture ✨</h3>
        <p>
            Want a more accurate cosmic reading?<br />
            Let us capture your current vibe ✨<br />
            <strong>(Just for fun — nothing stored)</strong>
        </p>
        <video id="cameraVideo" class="camera-video hidden" autoplay playsinline muted></video>
        <div id="countdown" class="countdown hidden">3</div>
        <div class="modal-actions">
            <button id="captureVibeBtn" class="cta-btn primary">Capture my vibe ✨</button>
            <button id="skipVibeBtn" class="cta-btn ghost">Skip (still magical)</button>
        </div>
    </div>
</div>

<script>
    const IS_LOCAL_MODE = @Html.Raw(isLocalMode);
    const HISTORY_KEY = "aibabag-history-v1";
    const MOODS = [
        "🌞 Radiant Energy",
        "🌊 Calm Energy",
        "⚡ Expressive Energy",
        "🌙 Reflective Energy",
        "🔥 Intense Energy"
    ];

    const state = {
        userId: null,
        mode: "google",
        profile: null,
        mood: null,
        history: [],
        stream: null,
        generated: null
    };

    const ui = {
        heroSection: document.getElementById("heroSection"),
        experience: document.getElementById("experience"),
        googleBtn: document.getElementById("googleBtn"),
        guestBtn: document.getElementById("guestBtn"),
        logoutBtn: document.getElementById("logoutBtn"),
        avatarImage: document.getElementById("avatarImage"),
        avatarFallback: document.getElementById("avatarFallback"),
        welcomeTitle: document.getElementById("welcomeTitle"),
        moodTitle: document.getElementById("moodTitle"),
        moodLine: document.getElementById("moodLine"),
        snapshotGrid: document.getElementById("snapshotGrid"),
        spiritAnimalTitle: document.getElementById("spiritAnimalTitle"),
        spiritAnimalLine: document.getElementById("spiritAnimalLine"),
        birthdayCards: document.getElementById("birthdayCards"),
        insightCards: document.getElementById("insightCards"),
        sharePreview: document.getElementById("sharePreview"),
        shareImageBtn: document.getElementById("shareImageBtn"),
        copyLinkBtn: document.getElementById("copyLinkBtn"),
        downloadBtn: document.getElementById("downloadBtn"),
        historyCards: document.getElementById("historyCards"),
        cameraModal: document.getElementById("cameraModal"),
        cameraVideo: document.getElementById("cameraVideo"),
        countdown: document.getElementById("countdown"),
        captureVibeBtn: document.getElementById("captureVibeBtn"),
        skipVibeBtn: document.getElementById("skipVibeBtn"),
        facebookToken: document.getElementById("facebookToken"),
        facebookPageId: document.getElementById("facebookPageId"),
        facebookPostBtn: document.getElementById("facebookPostBtn"),
        linkedInToken: document.getElementById("linkedInToken"),
        linkedInUrn: document.getElementById("linkedInUrn"),
        linkedInPostBtn: document.getElementById("linkedInPostBtn"),
        socialStatus: document.getElementById("socialStatus")
    };

    init();

    async function init() {
        bindEvents();
        if (!IS_LOCAL_MODE) {
            ui.guestBtn.classList.add("hidden");
        }
        loadHistory();
        await hydrateAuth();
        renderHistory();
    }

    function bindEvents() {
        ui.googleBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/login?returnUrl=/";
        });
        ui.guestBtn.addEventListener("click", startGuestMode);
        ui.logoutBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/logout";
        });
        ui.captureVibeBtn.addEventListener("click", captureVibeFlow);
        ui.skipVibeBtn.addEventListener("click", skipVibeFlow);
        ui.shareImageBtn.addEventListener("click", shareImage);
        ui.copyLinkBtn.addEventListener("click", copyLink);
        ui.downloadBtn.addEventListener("click", downloadShareCard);
        ui.facebookPostBtn.addEventListener("click", () => postToSocial("facebook"));
        ui.linkedInPostBtn.addEventListener("click", () => postToSocial("linkedin"));
    }

    async function hydrateAuth() {
        try {
            const res = await fetch("/api/auth/status");
            const auth = await res.json();
            if (!auth?.isAuthenticated) {
                return;
            }

            state.userId = auth.userId;
            state.mode = "google";
            const dob = await fetchGoogleBirthday();
            const randomDob = randomDateString();
            state.profile = {
                name: auth.userName || "Cosmic Human",
                email: auth.email || "unknown@aibabag.com",
                dateOfBirth: dob || auth.dateOfBirth || randomDob,
                avatar: auth.profileImageUrl || "",
                isGuest: false
            };

            await loadServerHistory();
            launchExperience();
        } catch {
            // Landing stays visible when auth check fails.
        }
    }

    async function fetchGoogleBirthday() {
        try {
            const response = await fetch("/api/auth/google-birthday");
            if (!response.ok) {
                return null;
            }
            const payload = await response.json();
            return payload?.birthDate ? String(payload.birthDate).slice(0, 10) : null;
        } catch {
            return null;
        }
    }

    function startGuestMode() {
        state.mode = "guest";
        state.profile = {
            name: randomItem(["Luna Spark", "Nova Bloom", "Solar Jinx", "Astra Vibe", "Mira Orbit"]),
            email: "guest@local.dev",
            dateOfBirth: randomDateString(),
            avatar: "",
            isGuest: true
        };
        launchExperience();
    }

    function launchExperience() {
        ui.heroSection.classList.add("hidden");
        ui.experience.classList.remove("hidden");
        ui.logoutBtn.classList.toggle("hidden", state.profile?.isGuest ?? true);
        ui.welcomeTitle.textContent = `Hey ${state.profile.name} 👋`;
        renderAvatar();
        openCameraModal();
    }

    function renderAvatar() {
        const avatarUrl = state.profile?.avatar;
        if (avatarUrl) {
            ui.avatarImage.src = avatarUrl;
            ui.avatarImage.classList.remove("hidden");
            ui.avatarFallback.classList.add("hidden");
            return;
        }

        ui.avatarImage.classList.add("hidden");
        ui.avatarFallback.classList.remove("hidden");
        ui.avatarFallback.textContent = initials(state.profile.name);
    }

    function openCameraModal() {
        ui.cameraModal.classList.remove("hidden");
    }

    async function skipVibeFlow() {
        state.mood = randomItem(MOODS);
        closeCameraModal();
        await generateAndRender();
    }

    async function captureVibeFlow() {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            await skipVibeFlow();
            return;
        }

        try {
            state.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
            ui.cameraVideo.classList.remove("hidden");
            ui.cameraVideo.srcObject = state.stream;
            await runCountdown();
            const label = captureMoodLabel(ui.cameraVideo);
            stopCamera();
            state.mood = label;
            closeCameraModal();
            await generateAndRender();
        } catch {
            stopCamera();
            await skipVibeFlow();
        }
    }

    function stopCamera() {
        if (!state.stream) {
            return;
        }
        for (const track of state.stream.getTracks()) {
            track.stop();
        }
        state.stream = null;
        ui.cameraVideo.srcObject = null;
        ui.cameraVideo.classList.add("hidden");
    }

    async function runCountdown() {
        ui.countdown.classList.remove("hidden");
        for (const n of [3, 2, 1]) {
            ui.countdown.textContent = String(n);
            await delay(500);
        }
        ui.countdown.classList.add("hidden");
    }

    function captureMoodLabel(video) {
        const canvas = document.createElement("canvas");
        canvas.width = video.videoWidth || 480;
        canvas.height = video.videoHeight || 360;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
        let brightness = 0;
        for (let i = 0; i < data.length; i += 32) {
            brightness += (data[i] + data[i + 1] + data[i + 2]) / 3;
        }
        const score = Math.floor(brightness) % 5;
        return MOODS[score];
    }

    function closeCameraModal() {
        ui.cameraModal.classList.add("hidden");
    }

    async function generateAndRender() {
        const zodiac = zodiacFromDate(state.profile.dateOfBirth);
        const chinese = chineseZodiacFromDate(state.profile.dateOfBirth);
        const element = elementFromZodiac(zodiac);
        const destiny = destinyVibe(zodiac);
        const spirit = spiritAnimal(zodiac, state.mood);
        const famousPeople = getBirthdayCelebs(state.profile.dateOfBirth);
        const funInsights = personalityInsights(zodiac, state.mood);

        let quickInsights = {
            personalityTraits: funInsights.traitLine,
            healthInsights: funInsights.healthLine,
            careerInsights: funInsights.careerLine,
            loveInsights: funInsights.loveLine
        };

        if (!state.profile.isGuest && state.userId) {
            try {
                const res = await fetch("/api/insights/generate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        dateOfBirth: state.profile.dateOfBirth,
                        photoHint: state.mood
                    })
                });
                if (res.ok) {
                    const payload = await res.json();
                    quickInsights = payload?.data?.insights ?? quickInsights;
                }
            } catch {
                // Keep local generated copy when API call fails.
            }
        }

        state.generated = {
            createdAt: new Date().toISOString(),
            name: state.profile.name,
            dateOfBirth: state.profile.dateOfBirth,
            mood: state.mood,
            zodiac,
            chinese,
            element,
            destiny,
            spirit,
            quickInsights,
            famousPeople,
            funInsights
        };

        renderGenerated();
        persistHistory();
    }

    function renderGenerated() {
        const g = state.generated;
        ui.moodTitle.textContent = `${g.mood}`;
        ui.moodLine.textContent = moodOneLiner(g.mood);

        ui.snapshotGrid.innerHTML = [
            ["♈", "Zodiac sign", g.zodiac],
            ["🐉", "Chinese zodiac", g.chinese],
            ["🔥", "Element", g.element],
            ["✨", "Destiny vibe", g.destiny]
        ].map(([emoji, label, value]) => card(emoji, label, value)).join("");

        ui.spiritAnimalTitle.textContent = `${g.spirit.emoji} Spirit Animal Today: ${g.spirit.name}`;
        ui.spiritAnimalLine.textContent = g.spirit.line;

        ui.birthdayCards.innerHTML = g.famousPeople
            .map(person => `
                <article class="person-card">
                    <div class="person-photo">${person.photo}</div>
                    <h4>${escapeHtml(person.name)}</h4>
                    <p>${escapeHtml(person.trait)}</p>
                </article>`)
            .join("");

        ui.insightCards.innerHTML = [
            ["💡 Hidden strength", g.funInsights.hiddenStrength],
            ["🌪 Chaos trait", g.funInsights.chaosTrait],
            ["😶 Misunderstood vibe", g.funInsights.misunderstood]
        ]
            .map(([title, line]) => `
                <article class="insight-card">
                    <h4>${title}</h4>
                    <p>${escapeHtml(line)}</p>
                </article>`)
            .join("");

        ui.sharePreview.innerHTML =
            `I just discovered my cosmic personality ✨<br/>` +
            `${escapeHtml(g.name)} • ${escapeHtml(g.mood)} • ${escapeHtml(g.zodiac)}<br/>` +
            `Aibabag`;
    }

    async function postToSocial(provider) {
        const accessToken = provider === "facebook" ? ui.facebookToken.value.trim() : ui.linkedInToken.value.trim();
        if (!accessToken) {
            ui.socialStatus.textContent = `Add your ${provider} token first.`;
            return;
        }

        const message = `I just discovered my cosmic personality ✨ ${state.generated?.mood || ""} #Aibabag`;
        const body = {
            provider,
            message,
            accessToken,
            facebookPageId: ui.facebookPageId.value.trim(),
            linkedInPersonUrn: ui.linkedInUrn.value.trim()
        };

        ui.socialStatus.textContent = `Posting to ${provider}...`;

        try {
            const response = await fetch("/api/social/post", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });
            const payload = await response.json();
            if (!response.ok || !payload.success) {
                throw new Error(payload.message || "Post failed.");
            }
            ui.socialStatus.textContent = `${provider} post successful ✨`;
        } catch (error) {
            ui.socialStatus.textContent = error.message || "Post failed.";
        }
    }

    async function shareImage() {
        const blob = await createShareImageBlob();
        if (!blob) {
            return;
        }
        const file = new File([blob], "aibabag-share.png", { type: "image/png" });
        if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({
                files: [file],
                title: "AIBABAG",
                text: "I just discovered my cosmic personality ✨"
            });
            return;
        }
        await copyLink();
    }

    async function copyLink() {
        await navigator.clipboard.writeText(window.location.href);
    }

    async function downloadShareCard() {
        const blob = await createShareImageBlob();
        if (!blob) {
            return;
        }
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "aibabag-cosmic-share.png";
        a.click();
        URL.revokeObjectURL(url);
    }

    async function createShareImageBlob() {
        if (!state.generated) {
            return null;
        }
        const canvas = document.createElement("canvas");
        canvas.width = 1080;
        canvas.height = 1080;
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
        gradient.addColorStop(0, "#4b2dff");
        gradient.addColorStop(0.5, "#a347ff");
        gradient.addColorStop(1, "#ff7a8a");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.fillStyle = "rgba(255,255,255,0.95)";
        ctx.fillRect(70, 110, 940, 860);
        ctx.fillStyle = "#1f2052";
        ctx.font = "700 56px Inter, sans-serif";
        ctx.fillText("I just discovered my cosmic personality ✨", 120, 250);
        ctx.font = "500 44px Inter, sans-serif";
        ctx.fillText(`${state.generated.name} • ${state.generated.zodiac}`, 120, 360);
        ctx.fillText(`${state.generated.mood}`, 120, 430);
        ctx.font = "600 46px Inter, sans-serif";
        ctx.fillText("AIBABAG", 120, 810);

        return new Promise(resolve => canvas.toBlob(resolve, "image/png"));
    }

    function persistHistory() {
        const entry = {
            id: crypto.randomUUID(),
            at: state.generated.createdAt,
            mood: state.generated.mood,
            zodiac: state.generated.zodiac,
            name: state.generated.name,
            line: state.generated.funInsights.hiddenStrength
        };
        state.history = dedupeHistory([entry, ...state.history]).slice(0, 12);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        renderHistory();
    }

    function loadHistory() {
        try {
            const raw = localStorage.getItem(HISTORY_KEY);
            state.history = raw ? JSON.parse(raw) : [];
        } catch {
            state.history = [];
        }
    }

    async function loadServerHistory() {
        if (!state.userId || state.profile?.isGuest) {
            return;
        }

        try {
            const response = await fetch("/api/insights/history");
            if (!response.ok) {
                return;
            }

            const payload = await response.json();
            if (!payload?.success || !Array.isArray(payload.history)) {
                return;
            }

            const mapped = payload.history.map(item => ({
                id: item.id ? `server-${item.id}` : crypto.randomUUID(),
                at: item.calculatedAt || new Date().toISOString(),
                mood: item.luckyColor ? `✨ ${item.luckyColor}` : "✨ Cosmic Energy",
                zodiac: item.zodiacSign || "Unknown",
                name: state.profile?.name || "Cosmic Human",
                line: item.personalityTraits || item.careerInsights || "Cosmic memory unlocked."
            }));

            state.history = dedupeHistory([...mapped, ...state.history]).slice(0, 12);
            localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        } catch {
            // Silent fallback to local history.
        }
    }

    function dedupeHistory(items) {
        const seen = new Set();
        return items.filter(item => {
            const key = `${item.at}|${item.mood}|${item.zodiac}|${item.line}`;
            if (seen.has(key)) {
                return false;
            }
            seen.add(key);
            return true;
        });
    }

    function renderHistory() {
        if (!state.history.length) {
            ui.historyCards.innerHTML = `<article class="memory-card">Your next cosmic read will appear here ✨</article>`;
            return;
        }

        ui.historyCards.innerHTML = state.history
            .map(item => `
                <article class="memory-card">
                    <h4>${escapeHtml(item.mood)}</h4>
                    <p>${escapeHtml(item.name)} • ${escapeHtml(item.zodiac)}</p>
                    <small>${escapeHtml(item.line)}</small>
                </article>`)
            .join("");
    }

    function zodiacFromDate(dateText) {
        const date = new Date(dateText);
        const month = date.getMonth() + 1;
        const day = date.getDate();
        if ((month === 3 && day >= 21) || (month === 4 && day <= 19)) return "Aries";
        if ((month === 4 && day >= 20) || (month === 5 && day <= 20)) return "Taurus";
        if ((month === 5 && day >= 21) || (month === 6 && day <= 20)) return "Gemini";
        if ((month === 6 && day >= 21) || (month === 7 && day <= 22)) return "Cancer";
        if ((month === 7 && day >= 23) || (month === 8 && day <= 22)) return "Leo";
        if ((month === 8 && day >= 23) || (month === 9 && day <= 22)) return "Virgo";
        if ((month === 9 && day >= 23) || (month === 10 && day <= 22)) return "Libra";
        if ((month === 10 && day >= 23) || (month === 11 && day <= 21)) return "Scorpio";
        if ((month === 11 && day >= 22) || (month === 12 && day <= 21)) return "Sagittarius";
        if ((month === 12 && day >= 22) || (month === 1 && day <= 19)) return "Capricorn";
        if ((month === 1 && day >= 20) || (month === 2 && day <= 18)) return "Aquarius";
        return "Pisces";
    }

    function chineseZodiacFromDate(dateText) {
        const animals = ["Rat", "Ox", "Tiger", "Rabbit", "Dragon", "Snake", "Horse", "Goat", "Monkey", "Rooster", "Dog", "Pig"];
        const year = new Date(dateText).getFullYear();
        return animals[(year - 1900) % 12];
    }

    function elementFromZodiac(zodiac) {
        if (["Aries", "Leo", "Sagittarius"].includes(zodiac)) return "Fire";
        if (["Taurus", "Virgo", "Capricorn"].includes(zodiac)) return "Earth";
        if (["Gemini", "Libra", "Aquarius"].includes(zodiac)) return "Air";
        return "Water";
    }

    function destinyVibe(zodiac) {
        const map = {
            Aries: "Born to launch things before anyone asks.",
            Taurus: "Luxury with a side of unstoppable focus.",
            Gemini: "Multiplayer brain with sparkle mode on.",
            Cancer: "Soft heart, tactical instincts, deep memory.",
            Leo: "Main stage energy with loyal leadership.",
            Virgo: "Precision, wit, and low-key world domination.",
            Libra: "Style, balance, and social diplomacy.",
            Scorpio: "Mysterious magnetism with laser focus.",
            Sagittarius: "Adventure energy with truth bombs.",
            Capricorn: "Quiet ambition with premium execution.",
            Aquarius: "Future mind, rebel heart, big ideas.",
            Pisces: "Dreamy intuition with artistic chaos."
        };
        return map[zodiac] || "Cosmic wildcard vibes.";
    }

    function spiritAnimal(zodiac, mood) {
        const moodKey = mood || randomItem(MOODS);
        const picks = {
            "🌞 Radiant Energy": { emoji: "🦁", name: "Solar Lion", line: "You enter rooms like a soundtrack drop." },
            "🌊 Calm Energy": { emoji: "🦦", name: "Peace Otter", line: "Soft energy, strategic brain, zero panic." },
            "⚡ Expressive Energy": { emoji: "🦜", name: "Electric Parrot", line: "Colorful thoughts and no boring sentences." },
            "🌙 Reflective Energy": { emoji: "🦊", name: "Night Fox", line: "Quiet outside, plotting greatness inside." },
            "🔥 Intense Energy": { emoji: "🐅", name: "Wild Tiger", line: "Focused fire with magnetic confidence." }
        };
        return picks[moodKey];
    }

    function getBirthdayCelebs(dateText) {
        const key = dateText.slice(5);
        const map = {
            "01-17": [
                { photo: "🎤", name: "Legend Singer", trait: "Known for dangerous creativity." },
                { photo: "🎬", name: "Iconic Actor", trait: "Turns dramatic moments into memes." }
            ],
            "06-01": [
                { photo: "⚽", name: "Famous Athlete", trait: "Competitive with suspiciously calm confidence." },
                { photo: "🎧", name: "Top Producer", trait: "Makes chaos sound expensive." }
            ],
            "10-31": [
                { photo: "👑", name: "Cult Favorite Star", trait: "Charming in a slightly chaotic way." },
                { photo: "📚", name: "Brilliant Author", trait: "Emotionally devastating one-liners." }
            ]
        };
        return map[key] ?? [
            { photo: "🎭", name: "Global Entertainer", trait: "Known for instant scene-stealing." },
            { photo: "🚀", name: "Visionary Founder", trait: "Builds wild ideas like daily routine." },
            { photo: "🎨", name: "Creative Icon", trait: "Makes minimal effort look iconic." }
        ];
    }

    function personalityInsights(zodiac, mood) {
        const tone = moodOneLiner(mood);
        return {
            hiddenStrength: `${zodiac} power move: you stay cool while everyone else reloads emotionally.`,
            chaosTrait: `You call it spontaneity. Your calendar calls it performance art.`,
            misunderstood: `People think you're chill. You're actually in premium strategy mode.`,
            traitLine: `${zodiac} with ${mood} feels like charisma with a plot twist.`,
            healthLine: `Your vibe says: hydrate, breathe, and stop over-booking your soul.`,
            careerLine: `Today favors bold asks and tiny dramatic exits from boring tasks.`,
            loveLine: `Your cosmic signal says romance improves when you text first and overthink less.`,
            moodLine: tone
        };
    }

    function moodOneLiner(mood) {
        const lines = {
            "🌞 Radiant Energy": "Bright aura. You could compliment a plant and it would bloom faster.",
            "🌊 Calm Energy": "Calm ocean energy. You look peaceful, which scares your enemies.",
            "⚡ Expressive Energy": "Electric vibe. Your personality has subtitles and sound effects.",
            "🌙 Reflective Energy": "Moonlit energy. Deep thoughts, soft voice, dangerous intuition.",
            "🔥 Intense Energy": "Fire mode. You are politely unstoppable today."
        };
        return lines[mood] || "Cosmic sparkle detected.";
    }

    function card(emoji, label, value) {
        return `<article class="snap-card"><p>${emoji} ${escapeHtml(label)}</p><h4>${escapeHtml(value)}</h4></article>`;
    }

    function randomDateString() {
        const year = 1990 + Math.floor(Math.random() * 15);
        const month = 1 + Math.floor(Math.random() * 12);
        const day = 1 + Math.floor(Math.random() * 28);
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
    }

    function randomItem(items) {
        return items[Math.floor(Math.random() * items.length)];
    }

    function initials(name) {
        return name.split(" ").map(x => x[0]).join("").slice(0, 2).toUpperCase();
    }

    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function escapeHtml(text) {
        return String(text)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }
</script>

<style>
    :root {
        --ink: #161833;
        --muted: #6e7399;
        --panel: #ffffff;
        --line: #e4e7fb;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, "Segoe UI", sans-serif;
        color: var(--ink);
        background: radial-gradient(circle at 20% 0%, #ffe4fb 0%, #efeaff 25%, #e7eeff 45%, #f8f9ff 100%);
