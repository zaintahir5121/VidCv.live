@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@{
    ViewData["Title"] = "AI-BABA-G";
    var isLocalMode = HostingEnvironment.IsDevelopment().ToString().ToLowerInvariant();
}

<div id="appRoot" class="app-root">
    <section id="landingView" class="landing-view">
        <div class="stars-layer"></div>
        <div class="orb orb-a"></div>
        <div class="orb orb-b"></div>
        <div class="orb orb-c"></div>

        <header class="landing-header glass">
            <div class="brand-mark">
                <span class="logo-planet">◎</span>
                <div>
                    <h1>AI-BABA-G</h1>
                    <p>Your Master Personality AI</p>
                </div>
            </div>
            <span class="mode-tag" id="modeTag">Production mode</span>
        </header>

        <div class="hero">
            <article class="hero-copy glass">
                <p class="hero-kicker">AI + Astrology + Feng Shui + Mood</p>
                <h2>AI-BABA-G — Decode Your Cosmic Blueprint</h2>
                <p class="hero-sub">Powered by AI. Inspired by Astrology. Built for Humans.</p>
                <p class="hero-sub">
                    We use your data only to personalize your experience:
                    name for greeting, DOB for zodiac intelligence, location for place suggestions, mood for current energy.
                </p>
                <div class="hero-ctas">
                    <button id="gmailBtn" class="btn btn-primary">Continue with Gmail</button>
                    <button id="guestBtn" class="btn btn-secondary">Try Guest Mode (Dev)</button>
                </div>
            </article>

            <article class="hero-visual glass">
                <div class="planet large"></div>
                <div class="planet medium"></div>
                <div class="planet tiny"></div>
                <div class="energy-ring"></div>
                <p>3D + 4D inspired visual zone</p>
            </article>
        </div>

        <section class="trust-strip">
            <article class="trust-card glass">
                <span>🛡️</span>
                <h4>No spam</h4>
                <p>Only meaningful insights.</p>
            </article>
            <article class="trust-card glass">
                <span>📷</span>
                <h4>No images stored</h4>
                <p>Camera is optional and temporary.</p>
            </article>
            <article class="trust-card glass">
                <span>✨</span>
                <h4>AI-powered, privacy-first</h4>
                <p>Minimal, purpose-driven data use.</p>
            </article>
            <article class="trust-card glass">
                <span>🔐</span>
                <h4>Your data stays yours</h4>
                <p>Built for trust and control.</p>
            </article>
        </section>
    </section>

    <section id="dobGateView" class="modal-view hidden">
        <article class="modal-card glass">
            <h3>Add your birthday to continue</h3>
            <p>We could not find your birthday from Gmail. Please enter it manually before opening your dashboard.</p>
            <input id="manualDobInput" type="date" />
            <button id="saveDobBtn" class="btn btn-primary">Save birthday and continue</button>
            <p id="manualDobError" class="error-line hidden"></p>
        </article>
    </section>

    <section id="dashboardView" class="dashboard hidden">
        <header class="dashboard-top glass">
            <div class="dash-brand">
                <span class="logo-planet">◎</span>
                <div>
                    <h2>AI-BABA-G</h2>
                    <p>Master Personality AI Experience</p>
                </div>
            </div>
            <div class="top-actions">
                <button id="logoutBtn" class="btn btn-secondary">Logout</button>
            </div>
        </header>

        <section class="welcome-card glass">
            <div class="welcome-left">
                <img id="profileImage" class="profile-image" alt="User avatar" />
                <div>
                    <h3 id="welcomeText">Hey User 👋 Welcome to Your AI-Cosmic Space</h3>
                    <p id="dataWhyText">Name, birthday, mood, and location power this personalized experience.</p>
                    <div class="meta-tags">
                        <span id="dobTag">DOB: --</span>
                        <span id="locationTag">Location: --</span>
                        <span id="zodiacTag">Zodiac: --</span>
                    </div>
                </div>
            </div>
            <div class="welcome-right">
                <p class="tiny-label">Cosmic mode</p>
                <h4 id="moodHeadline">🌊 Calm Ocean</h4>
                <p id="moodLine">You are peaceful today — dangerous tomorrow.</p>
                <div class="mood-actions">
                    <button id="cameraMoodBtn" class="btn btn-secondary">Capture mood (optional)</button>
                    <button id="randomMoodBtn" class="btn btn-secondary">Pick random mood</button>
                </div>
            </div>
        </section>

        <section class="grid-two">
            <article class="big-visual glass">
                <p class="tiny-label">Spirit Animal</p>
                <img id="spiritImage" alt="Spirit animal" />
                <h4 id="spiritTitle">🐯 Tiger</h4>
                <p id="spiritLine">Quiet strength. Loud when needed.</p>
            </article>

            <article class="big-visual glass">
                <p class="tiny-label">Food Energy</p>
                <div class="food-grid">
                    <figure><img id="foodA" alt="Grounding food" /><figcaption>Grounding foods</figcaption></figure>
                    <figure><img id="foodB" alt="High-energy food" /><figcaption>High-energy foods</figcaption></figure>
                    <figure><img id="foodC" alt="Comfort food" /><figcaption>Comfort foods</figcaption></figure>
                </div>
            </article>
        </section>

        <section class="places glass">
            <div class="section-title-row">
                <h3>Places You Should Visit</h3>
                <p id="placesHint">Based on your current region and today’s energy</p>
            </div>
            <div id="placesGrid" class="places-grid"></div>
        </section>

        <section class="life-flow glass">
            <div class="section-title-row">
                <h3>Life Flow</h3>
                <p>Visual pulse across your focus areas</p>
            </div>
            <div id="flowGrid" class="flow-grid"></div>
        </section>

        <section class="famous glass">
            <div class="section-title-row">
                <h3>Famous Personalities</h3>
                <p>Alive and historical figures linked to your birth energy</p>
            </div>
            <h4>Alive Today</h4>
            <div id="famousAlive" class="famous-grid"></div>
            <h4>From History</h4>
            <div id="famousHistory" class="famous-grid"></div>
        </section>

        <section class="suggestion glass">
            <div class="section-title-row">
                <h3>Suggestion for Your Current Mode</h3>
                <p>Playful actions based on energy, not medical advice</p>
            </div>
            <div id="suggestionGrid" class="suggestion-grid"></div>
        </section>

        <section class="share-box glass">
            <h3>I just discovered my AI-BABA-G cosmic personality ✨</h3>
            <p>Make it personal. Make it shareable.</p>
        </section>
    </section>

    <video id="cameraVideo" class="hidden" autoplay playsinline muted></video>
</div>

<script>
    const IS_LOCAL_MODE = @Html.Raw(isLocalMode);
    const DEFAULT_PROFILE_IMAGE = "https://images.unsplash.com/photo-1542206395-9feb3edaa68d?auto=format&fit=crop&w=800&q=80";

    const ui = {
        landingView: document.getElementById("landingView"),
        dobGateView: document.getElementById("dobGateView"),
        dashboardView: document.getElementById("dashboardView"),
        modeTag: document.getElementById("modeTag"),
        gmailBtn: document.getElementById("gmailBtn"),
        guestBtn: document.getElementById("guestBtn"),
        saveDobBtn: document.getElementById("saveDobBtn"),
        manualDobInput: document.getElementById("manualDobInput"),
        manualDobError: document.getElementById("manualDobError"),
        logoutBtn: document.getElementById("logoutBtn"),
        profileImage: document.getElementById("profileImage"),
        welcomeText: document.getElementById("welcomeText"),
        dataWhyText: document.getElementById("dataWhyText"),
        dobTag: document.getElementById("dobTag"),
        locationTag: document.getElementById("locationTag"),
        zodiacTag: document.getElementById("zodiacTag"),
        moodHeadline: document.getElementById("moodHeadline"),
        moodLine: document.getElementById("moodLine"),
        cameraMoodBtn: document.getElementById("cameraMoodBtn"),
        randomMoodBtn: document.getElementById("randomMoodBtn"),
        spiritImage: document.getElementById("spiritImage"),
        spiritTitle: document.getElementById("spiritTitle"),
        spiritLine: document.getElementById("spiritLine"),
        foodA: document.getElementById("foodA"),
        foodB: document.getElementById("foodB"),
        foodC: document.getElementById("foodC"),
        placesHint: document.getElementById("placesHint"),
        placesGrid: document.getElementById("placesGrid"),
        flowGrid: document.getElementById("flowGrid"),
        famousAlive: document.getElementById("famousAlive"),
        famousHistory: document.getElementById("famousHistory"),
        suggestionGrid: document.getElementById("suggestionGrid"),
        cameraVideo: document.getElementById("cameraVideo")
    };

    const state = {
        userId: null,
        profile: null,
        mood: "🌊 Calm Ocean",
        location: "Unknown",
        stream: null,
        fallbackText: {}
    };

    const moodPool = [
        "🌊 Calm Ocean",
        "🔥 Bold Fire",
        "⚡ Electric Focus",
        "🌙 Reflective Moon",
        "🌞 Bright Rise"
    ];

    const spiritByMood = {
        "🌊 Calm Ocean": {
            emoji: "🦢",
            name: "Swan",
            line: "Graceful balance under pressure.",
            image: "https://images.unsplash.com/photo-1474511320723-9a56873867b5?auto=format&fit=crop&w=1200&q=80"
        },
        "🔥 Bold Fire": {
            emoji: "🐅",
            name: "Tiger",
            line: "Quiet strength. Loud when needed.",
            image: "https://images.unsplash.com/photo-1549480017-d76466a4b7e8?auto=format&fit=crop&w=1200&q=80"
        },
        "⚡ Electric Focus": {
            emoji: "🦅",
            name: "Eagle",
            line: "Laser focus and fearless decisions.",
            image: "https://images.unsplash.com/photo-1552728089-57bdde30beb3?auto=format&fit=crop&w=1200&q=80"
        },
        "🌙 Reflective Moon": {
            emoji: "🦉",
            name: "Owl",
            line: "Deep intuition, subtle power.",
            image: "https://images.unsplash.com/photo-1501706362039-c6e08f4bbfff?auto=format&fit=crop&w=1200&q=80"
        },
        "🌞 Bright Rise": {
            emoji: "🦁",
            name: "Lion",
            line: "Warm confidence with natural leadership.",
            image: "https://images.unsplash.com/photo-1546182990-dffeafbe841d?auto=format&fit=crop&w=1200&q=80"
        }
    };

    const foodImages = [
        "https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1512058564366-18510be2db19?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=1200&q=80"
    ];

    const placeThemes = [
        { icon: "🌿", label: "Nature", image: "https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1000&q=80" },
        { icon: "☕", label: "Cafe", image: "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1000&q=80" },
        { icon: "🕉️", label: "Spiritual", image: "https://images.unsplash.com/photo-1476231682828-37e571bc172f?auto=format&fit=crop&w=1000&q=80" },
        { icon: "✈️", label: "Travel", image: "https://images.unsplash.com/photo-1488085061387-422e29b40080?auto=format&fit=crop&w=1000&q=80" }
    ];

    const flowItems = [
        { icon: "👑", label: "Leadership" },
        { icon: "📈", label: "Growth" },
        { icon: "💼", label: "Career" },
        { icon: "📚", label: "Knowledge" },
        { icon: "🧘", label: "Mind & Body" },
        { icon: "❤️", label: "Relationships" },
        { icon: "💡", label: "Inspiration" },
        { icon: "🍀", label: "Lucky Elements" }
    ];

    init();

    async function init() {
        wireEvents();
        ui.modeTag.textContent = IS_LOCAL_MODE ? "Dev mode enabled" : "Production mode";
        if (!IS_LOCAL_MODE) {
            ui.guestBtn.classList.add("hidden");
        }

        if (IS_LOCAL_MODE) {
            startGuestFlow();
            return;
        }

        const auth = await hydrateAuth();
        if (!auth) {
            showLanding();
            return;
        }

        if (!state.profile.dateOfBirth) {
            showDobGate();
            return;
        }

        await openDashboard();
    }

    function wireEvents() {
        ui.gmailBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/login?returnUrl=/";
        });
        ui.guestBtn.addEventListener("click", startGuestFlow);
        ui.saveDobBtn.addEventListener("click", saveManualDob);
        ui.logoutBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/logout";
        });
        ui.randomMoodBtn.addEventListener("click", async () => {
            state.mood = randomItem(moodPool);
            await openDashboard();
        });
        ui.cameraMoodBtn.addEventListener("click", detectMoodFromCamera);
    }

    function startGuestFlow() {
        state.userId = 0;
        state.profile = {
            name: randomItem(["Luna Ray", "Nova Sky", "Astra Joy", "Mira Flux"]),
            email: "guest@local.dev",
            dateOfBirth: randomDate(),
            avatar: "",
            zodiacSign: ""
        };
        state.location = "Local Dev City";
        state.mood = randomItem(moodPool);
        openDashboard();
    }

    async function hydrateAuth() {
        try {
            const response = await fetch("/api/auth/status");
            if (!response.ok) return false;
            const auth = await response.json();
            if (!auth?.isAuthenticated) return false;

            state.userId = auth.userId;
            const googleDob = await fetchGoogleBirthday();
            state.profile = {
                name: auth.userName || "AI-BABA-G User",
                email: auth.email || "user@gmail.com",
                dateOfBirth: googleDob || auth.dateOfBirth || "",
                avatar: auth.profileImageUrl || "",
                zodiacSign: ""
            };
            await hydrateLocation();
            return true;
        } catch {
            return false;
        }
    }

    async function fetchGoogleBirthday() {
        try {
            const response = await fetch("/api/auth/google-birthday");
            if (!response.ok) return "";
            const payload = await response.json();
            return payload?.birthDate ? String(payload.birthDate).slice(0, 10) : "";
        } catch {
            return "";
        }
    }

    async function hydrateLocation() {
        try {
            const response = await fetch("https://ipapi.co/json/");
            if (!response.ok) {
                state.location = "Unknown";
                return;
            }
            const payload = await response.json();
            const city = payload?.city || "Unknown";
            const country = payload?.country_name || "";
            state.location = country ? `${city}, ${country}` : city;
        } catch {
            state.location = "Unknown";
        }
    }

    function showLanding() {
        ui.landingView.classList.remove("hidden");
        ui.dobGateView.classList.add("hidden");
        ui.dashboardView.classList.add("hidden");
    }

    function showDobGate() {
        ui.landingView.classList.add("hidden");
        ui.dobGateView.classList.remove("hidden");
        ui.dashboardView.classList.add("hidden");
    }

    function showDashboard() {
        ui.landingView.classList.add("hidden");
        ui.dobGateView.classList.add("hidden");
        ui.dashboardView.classList.remove("hidden");
    }

    async function saveManualDob() {
        const value = ui.manualDobInput.value;
        if (!value) {
            ui.manualDobError.classList.remove("hidden");
            ui.manualDobError.textContent = "Please choose your date of birth.";
            return;
        }

        try {
            const response = await fetch("/api/auth/set-birthday", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ dateOfBirth: value })
            });
            if (!response.ok) {
                ui.manualDobError.classList.remove("hidden");
                ui.manualDobError.textContent = "Could not save DOB. Please try again.";
                return;
            }
            const payload = await response.json();
            state.profile.dateOfBirth = payload?.birthDate || value;
            ui.manualDobError.classList.add("hidden");
            await openDashboard();
        } catch {
            ui.manualDobError.classList.remove("hidden");
            ui.manualDobError.textContent = "Network issue while saving DOB.";
        }
    }

    async function openDashboard() {
        showDashboard();
        const dob = state.profile.dateOfBirth || randomDate();
        const zodiac = zodiacFromDate(dob);
        state.profile.zodiacSign = zodiac;

        ui.profileImage.src = safeImage(state.profile.avatar || DEFAULT_PROFILE_IMAGE);
        ui.welcomeText.textContent = `Hey ${state.profile.name} 👋 Welcome to Your AI-Cosmic Space`;
        ui.dataWhyText.textContent = "Data use: Name for greeting • DOB for astrology • IP location for place ideas • Mood for playful suggestions.";
        ui.dobTag.textContent = `DOB: ${dob}`;
        ui.locationTag.textContent = `Location: ${state.location}`;
        ui.zodiacTag.textContent = `Zodiac: ${zodiac}`;

        ui.moodHeadline.textContent = `Today’s Energy: ${state.mood}`;
        ui.moodLine.textContent = moodOneLiner(state.mood);

        await hydrateFallbackText(zodiac, dob);
        renderSpiritAnimal();
        renderFoodEnergy();
        renderPlaces();
        renderLifeFlow();
        await renderFamous(dob);
        renderSuggestions();
    }

    async function hydrateFallbackText(zodiac, dob) {
        try {
            const response = await fetch("/api/insights/ai-fallback", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ zodiacSign: zodiac, dateOfBirth: dob })
            });
            if (!response.ok) {
                state.fallbackText = {};
                return;
            }
            const payload = await response.json();
            state.fallbackText = payload?.data || {};
        } catch {
            state.fallbackText = {};
        }
    }

    function renderSpiritAnimal() {
        const spirit = spiritByMood[state.mood] || spiritByMood["🌊 Calm Ocean"];
        ui.spiritImage.src = safeImage(spirit.image);
        ui.spiritTitle.textContent = `${spirit.emoji} ${spirit.name}`;
        ui.spiritLine.textContent = state.fallbackText?.animalLine || spirit.line;
    }

    function renderFoodEnergy() {
        ui.foodA.src = safeImage(foodImages[0]);
        ui.foodB.src = safeImage(foodImages[1]);
        ui.foodC.src = safeImage(foodImages[2]);
    }

    function renderPlaces() {
        ui.placesHint.textContent = `Based on IP region: ${state.location}`;
        ui.placesGrid.innerHTML = placeThemes.map(place => `
            <article class="place-card">
                <img src="${escapeHtml(place.image)}" alt="${escapeHtml(place.label)}" />
                <div>
                    <h4>${place.icon} ${escapeHtml(place.label)}</h4>
                    <p>${escapeHtml(state.location)} vibe pick</p>
                </div>
            </article>
        `).join("");
    }

    function renderLifeFlow() {
        ui.flowGrid.innerHTML = flowItems.map((item, idx) => `
            <article class="flow-item">
                <span>${item.icon}</span>
                <h4>${escapeHtml(item.label)}</h4>
                <div class="flow-line" style="width:${70 + (idx % 4) * 8}%"></div>
            </article>
        `).join("");
    }

    async function renderFamous(dob) {
        let people = [];
        try {
            const response = await fetch(`/api/insights/famous-by-birthday?dob=${encodeURIComponent(dob)}`);
            if (response.ok) {
                const payload = await response.json();
                people = Array.isArray(payload?.people) ? payload.people : [];
            }
        } catch {
            people = [];
        }

        if (!people.length) {
            people = fallbackFamous();
        }

        const alive = people.slice(0, 4).map(person => ({
            name: person.name || "Famous Personality",
            image: safeImage(person.imageUrl),
            line: person.summary || "Alive personality linked with your birth vibe."
        }));

        const history = people.slice(4, 8).map(person => ({
            name: person.name || "Historic Personality",
            image: safeImage(person.imageUrl),
            line: person.summary || "Historic inspiration aligned to your energy."
        }));

        ui.famousAlive.innerHTML = alive.map(person => `
            <article class="famous-card">
                <img src="${escapeHtml(person.image)}" alt="${escapeHtml(person.name)}" />
                <h4>${escapeHtml(person.name)}</h4>
                <p>${escapeHtml(person.line)}</p>
            </article>
        `).join("");

        ui.famousHistory.innerHTML = history.map(person => `
            <article class="famous-card">
                <img src="${escapeHtml(person.image)}" alt="${escapeHtml(person.name)}" />
                <h4>${escapeHtml(person.name)}</h4>
                <p>${escapeHtml(person.line)}</p>
            </article>
        `).join("");
    }

    function renderSuggestions() {
        const map = {
            "🌊 Calm Ocean": [
                "5-minute breathing challenge",
                "Slow stretch flow",
                "Cozy puzzle game"
            ],
            "🔥 Bold Fire": [
                "10-minute dance burst",
                "Quick reaction game",
                "Power walk challenge"
            ],
            "⚡ Electric Focus": [
                "Focus sprint timer",
                "Reflex mini-game",
                "One-goal execution challenge"
            ],
            "🌙 Reflective Moon": [
                "Journaling prompt",
                "Moon breathing cycle",
                "Silent art doodle"
            ],
            "🌞 Bright Rise": [
                "Sun salutation set",
                "Social gratitude message",
                "Creative one-page vision board"
            ]
        };

        const items = map[state.mood] || map["🌊 Calm Ocean"];
        ui.suggestionGrid.innerHTML = items.map((item, idx) => `
            <article class="suggestion-item">
                <h4>${idx + 1}. ${escapeHtml(item)}</h4>
                <p>${escapeHtml(state.fallbackText?.purposeLine || "Playful energy action based on your current mode.")}</p>
            </article>
        `).join("");
    }

    async function detectMoodFromCamera() {
        if (!navigator.mediaDevices?.getUserMedia) {
            state.mood = randomItem(moodPool);
            await openDashboard();
            return;
        }

        const allow = window.confirm("Want a more accurate cosmic reading? Camera is just for fun and nothing is stored.");
        if (!allow) {
            state.mood = randomItem(moodPool);
            await openDashboard();
            return;
        }

        try {
            state.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
            ui.cameraVideo.srcObject = state.stream;
            await delay(1100);
            state.mood = randomItem(moodPool);
        } catch {
            state.mood = randomItem(moodPool);
        } finally {
            stopCamera();
            await openDashboard();
        }
    }

    function stopCamera() {
        if (!state.stream) return;
        for (const track of state.stream.getTracks()) {
            track.stop();
        }
        state.stream = null;
        ui.cameraVideo.srcObject = null;
    }

    function zodiacFromDate(dateText) {
        const d = new Date(dateText);
        const m = d.getMonth() + 1;
        const day = d.getDate();
        if ((m === 3 && day >= 21) || (m === 4 && day <= 19)) return "Aries";
        if ((m === 4 && day >= 20) || (m === 5 && day <= 20)) return "Taurus";
        if ((m === 5 && day >= 21) || (m === 6 && day <= 20)) return "Gemini";
        if ((m === 6 && day >= 21) || (m === 7 && day <= 22)) return "Cancer";
        if ((m === 7 && day >= 23) || (m === 8 && day <= 22)) return "Leo";
        if ((m === 8 && day >= 23) || (m === 9 && day <= 22)) return "Virgo";
        if ((m === 9 && day >= 23) || (m === 10 && day <= 22)) return "Libra";
        if ((m === 10 && day >= 23) || (m === 11 && day <= 21)) return "Scorpio";
        if ((m === 11 && day >= 22) || (m === 12 && day <= 21)) return "Sagittarius";
        if ((m === 12 && day >= 22) || (m === 1 && day <= 19)) return "Capricorn";
        if ((m === 1 && day >= 20) || (m === 2 && day <= 18)) return "Aquarius";
        return "Pisces";
    }

    function fallbackFamous() {
        return [
            { name: "Emma Watson", summary: "Global icon with thoughtful influence.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/2/2f/Emma_Watson_2013.jpg" },
            { name: "Keanu Reeves", summary: "Calm charisma and timeless presence.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/6/6f/Keanu_Reeves_2013.jpg" },
            { name: "Beyonce", summary: "Creative force with commanding stage energy.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/3/3f/Beyonc%C3%A9_Knowles_2009.jpg" },
            { name: "Tom Holland", summary: "Energetic performer with joyful vibe.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/0/03/Tom_Holland_2018.jpg" },
            { name: "Maya Angelou", summary: "Historic storyteller who moved generations.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/0/09/Dr._Maya_Angelou.jpg" },
            { name: "Nikola Tesla", summary: "Visionary mind ahead of his time.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/d/d4/N.Tesla.JPG" },
            { name: "Frida Kahlo", summary: "Bold artistic expression and resilience.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/1/1f/Frida_Kahlo%2C_by_Guillermo_Kahlo.jpg" },
            { name: "Leonardo da Vinci", summary: "Master of creativity and curiosity.", imageUrl: "https://upload.wikimedia.org/wikipedia/commons/e/e2/Leonardo_da_Vinci_-_presumed_self-portrait_-_WGA12798.jpg" }
        ];
    }

    function moodOneLiner(mood) {
        const map = {
            "🌊 Calm Ocean": "You are peaceful today — dangerous tomorrow.",
            "🔥 Bold Fire": "Your confidence enters the room first.",
            "⚡ Electric Focus": "Today, your focus can cut through noise.",
            "🌙 Reflective Moon": "Soft tone, sharp intuition, strong choices.",
            "🌞 Bright Rise": "Your energy can spark everyone nearby."
        };
        return map[mood] || "Cosmic energy detected.";
    }

    function safeImage(url) {
        if (typeof url !== "string") return DEFAULT_PROFILE_IMAGE;
        if (url.startsWith("http://") || url.startsWith("https://")) return url;
        return DEFAULT_PROFILE_IMAGE;
    }

    function randomDate() {
        const year = 1990 + Math.floor(Math.random() * 15);
        const month = 1 + Math.floor(Math.random() * 12);
        const day = 1 + Math.floor(Math.random() * 28);
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
    }

    function randomItem(items) {
        return items[Math.floor(Math.random() * items.length)];
    }

    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function escapeHtml(text) {
        return String(text)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }
</script>

<style>
    :root {
        --bg: #050816;
        --panel: rgba(12, 18, 44, 0.74);
        --line: rgba(109, 139, 255, 0.35);
        --text: #eef2ff;
        --muted: #b8c4e7;
        --accent: #7b61ff;
        --accent2: #4be1ff;
        --accent3: #ff7ac8;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, "Segoe UI", sans-serif;
        color: var(--text);
        background:
            radial-gradient(circle at 18% 24%, rgba(85, 94, 255, 0.28), transparent 40%),
            radial-gradient(circle at 85% 10%, rgba(255, 102, 194, 0.2), transparent 35%),
            radial-gradient(circle at 50% 120%, rgba(39, 219, 255, 0.18), transparent 45%),
            var(--bg);
        min-height: 100vh;
    }

    .hidden {
        display: none !important;
    }

    .app-root {
        max-width: 1260px;
        margin: 0 auto;
        padding: 14px 14px 56px;
        display: grid;
        gap: 14px;
    }

    .glass {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
        backdrop-filter: blur(10px);
        box-shadow: 0 20px 46px rgba(4, 8, 25, 0.55);
    }

    .landing-view {
        position: relative;
        padding: 14px;
        overflow: hidden;
        min-height: 92vh;
        display: grid;
        align-content: start;
        gap: 14px;
    }

    .stars-layer {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(2px 2px at 12% 22%, rgba(255,255,255,.75) 45%, transparent 55%),
            radial-gradient(1.5px 1.5px at 38% 66%, rgba(255,255,255,.68) 45%, transparent 55%),
            radial-gradient(2px 2px at 74% 34%, rgba(255,255,255,.72) 45%, transparent 55%),
            radial-gradient(1.5px 1.5px at 90% 70%, rgba(255,255,255,.62) 45%, transparent 55%);
        pointer-events: none;
        opacity: .7;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(8px);
        opacity: .44;
        pointer-events: none;
        animation: floaty 8s ease-in-out infinite;
    }

    .orb-a {
        width: 260px;
        height: 260px;
        background: radial-gradient(circle, rgba(124,96,255,.72), rgba(124,96,255,0));
        top: -60px;
        right: 60px;
    }

    .orb-b {
        width: 220px;
        height: 220px;
        background: radial-gradient(circle, rgba(255,123,200,.66), rgba(255,123,200,0));
        bottom: 90px;
        left: -40px;
    }

    .orb-c {
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(71,227,255,.62), rgba(71,227,255,0));
        top: 44%;
        right: 28%;
    }

    .landing-header {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
    }

    .brand-mark {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .logo-planet {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        box-shadow: 0 0 28px rgba(98, 180, 255, 0.55);
        font-weight: 900;
    }

    .brand-mark h1,
    .dash-brand h2 {
        margin: 0;
        font-size: 1.05rem;
    }

    .brand-mark p,
    .dash-brand p,
    .mode-tag {
        margin: 0;
        font-size: .78rem;
        color: var(--muted);
    }

    .hero {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.2fr .8fr;
        gap: 14px;
    }

    .hero-copy,
    .hero-visual {
        padding: 20px;
    }

    .hero-kicker {
        margin: 0 0 8px;
        letter-spacing: .16em;
        font-size: .72rem;
        color: #bfe1ff;
    }

    .hero-copy h2 {
        margin: 0 0 10px;
        font-size: clamp(1.7rem, 3.3vw, 2.6rem);
        line-height: 1.15;
    }

    .hero-sub {
        margin: 0 0 10px;
        color: var(--muted);
        line-height: 1.45;
        max-width: 690px;
    }

    .hero-ctas {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .btn {
        border: none;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: .9rem;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-primary {
        color: #fff;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        box-shadow: 0 10px 24px rgba(106, 140, 255, .4);
    }

    .btn-secondary {
        color: #dce5ff;
        background: rgba(126, 145, 255, .16);
        border: 1px solid rgba(126, 145, 255, .34);
    }

    .hero-visual {
        position: relative;
        overflow: hidden;
        min-height: 270px;
    }

    .planet {
        position: absolute;
        border-radius: 50%;
        animation: drift 10s ease-in-out infinite;
    }

    .planet.large {
        width: 140px;
        height: 140px;
        background: radial-gradient(circle, rgba(131,112,255,.95), rgba(131,112,255,.2));
        top: 32px;
        right: 34px;
    }

    .planet.medium {
        width: 96px;
        height: 96px;
        background: radial-gradient(circle, rgba(66,225,255,.88), rgba(66,225,255,.2));
        bottom: 38px;
        left: 26px;
    }

    .planet.tiny {
        width: 46px;
        height: 46px;
        background: radial-gradient(circle, rgba(255,124,206,.92), rgba(255,124,206,.2));
        top: 128px;
        left: 52%;
    }

    .energy-ring {
        position: absolute;
        inset: 20px;
        border-radius: 22px;
        border: 1px dashed rgba(129, 170, 255, .35);
        animation: spin 12s linear infinite;
    }

    .hero-visual p {
        position: absolute;
        left: 20px;
        bottom: 16px;
        margin: 0;
        color: var(--muted);
    }

    .trust-strip {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
    }

    .trust-card {
        padding: 14px;
    }

    .trust-card span {
        font-size: 1.2rem;
    }

    .trust-card h4 {
        margin: 8px 0 5px;
    }

    .trust-card p {
        margin: 0;
        color: var(--muted);
        font-size: .87rem;
    }

    .modal-view {
        min-height: 72vh;
        display: grid;
        place-items: center;
    }

    .modal-card {
        width: min(640px, 100%);
        padding: 24px;
        text-align: center;
    }

    .modal-card h3 {
        margin: 0 0 8px;
    }

    .modal-card p {
        margin: 0 0 14px;
        color: var(--muted);
    }

    .modal-card input[type="date"] {
        width: min(340px, 100%);
        border-radius: 12px;
        border: 1px solid rgba(139, 161, 255, .35);
        background: rgba(17, 25, 55, .8);
        color: #eff4ff;
        padding: 10px 12px;
        margin-bottom: 12px;
    }

    .error-line {
        color: #ff9cb9 !important;
        margin-top: 8px !important;
    }

    .dashboard {
        display: grid;
        gap: 12px;
    }

    .dashboard-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 14px;
    }

    .dash-brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .welcome-card {
        display: grid;
        grid-template-columns: 1.2fr .8fr;
        gap: 14px;
        padding: 14px;
    }

    .welcome-left {
        display: flex;
        gap: 12px;
    }

    .profile-image {
        width: 86px;
        height: 86px;
        border-radius: 20px;
        object-fit: cover;
        border: 2px solid rgba(141, 163, 255, .42);
    }

    .welcome-left h3 {
        margin: 0 0 8px;
        font-size: 1.22rem;
    }

    .welcome-left p {
        margin: 0;
        color: var(--muted);
    }

    .meta-tags {
        display: flex;
        gap: 8px;
        margin-top: 9px;
        flex-wrap: wrap;
    }

    .meta-tags span {
        border-radius: 999px;
        border: 1px solid rgba(144, 165, 255, .3);
        background: rgba(119, 146, 255, .14);
        padding: 5px 9px;
        font-size: .78rem;
    }

    .welcome-right {
        border-radius: 16px;
        border: 1px solid rgba(121, 158, 255, .3);
        background: radial-gradient(circle at 70% 10%, rgba(114, 81, 255, .25), rgba(18, 28, 62, .7));
        padding: 12px;
    }

    .tiny-label {
        margin: 0;
        letter-spacing: .12em;
        font-size: .72rem;
        color: #c5d8ff;
    }

    .welcome-right h4 {
        margin: 7px 0 5px;
        font-size: 1.2rem;
    }

    .welcome-right p {
        margin: 0;
        color: var(--muted);
    }

    .mood-actions {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .grid-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .big-visual {
        padding: 12px;
    }

    .big-visual h4 {
        margin: 7px 0 6px;
    }

    .big-visual p {
        margin: 0;
        color: var(--muted);
    }

    .big-visual > img {
        width: 100%;
        height: 230px;
        border-radius: 14px;
        object-fit: cover;
        margin-top: 9px;
        border: 1px solid rgba(137, 162, 255, .28);
    }

    .food-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        margin-top: 10px;
    }

    .food-grid figure {
        margin: 0;
    }

    .food-grid img {
        width: 100%;
        height: 140px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid rgba(140, 166, 255, .3);
    }

    .food-grid figcaption {
        margin-top: 5px;
        text-align: center;
        color: var(--muted);
        font-size: .78rem;
    }

    .places,
    .life-flow,
    .famous,
    .suggestion,
    .share-box {
        padding: 12px;
    }

    .section-title-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .section-title-row h3 {
        margin: 0;
    }

    .section-title-row p {
        margin: 0;
        color: var(--muted);
        font-size: .85rem;
    }

    .places-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 9px;
    }

    .place-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(140, 166, 255, .3);
        background: rgba(16, 25, 56, .7);
    }

    .place-card img {
        width: 100%;
        height: 126px;
        object-fit: cover;
        display: block;
    }

    .place-card div {
        padding: 8px;
    }

    .place-card h4 {
        margin: 0 0 5px;
    }

    .place-card p {
        margin: 0;
        color: var(--muted);
        font-size: .8rem;
    }

    .flow-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .flow-item {
        border-radius: 12px;
        border: 1px solid rgba(138, 166, 255, .29);
        background: rgba(17, 26, 57, .7);
        padding: 10px;
    }

    .flow-item span {
        font-size: 1.2rem;
    }

    .flow-item h4 {
        margin: 7px 0 8px;
        font-size: .95rem;
    }

    .flow-line {
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3));
    }

    .famous-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 10px;
    }

    .famous h4 {
        margin: 6px 0 8px;
    }

    .famous-card {
        border-radius: 12px;
        border: 1px solid rgba(138, 167, 255, .29);
        background: rgba(17, 27, 58, .72);
        overflow: hidden;
    }

    .famous-card img {
        width: 100%;
        height: 132px;
        object-fit: cover;
        display: block;
    }

    .famous-card h4 {
        margin: 8px 8px 4px;
        font-size: .92rem;
    }

    .famous-card p {
        margin: 0 8px 9px;
        color: var(--muted);
        font-size: .8rem;
        line-height: 1.35;
    }

    .suggestion-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
    }

    .suggestion-item {
        border-radius: 12px;
        border: 1px solid rgba(139, 165, 255, .29);
        background: rgba(18, 28, 60, .72);
        padding: 10px;
    }

    .suggestion-item h4 {
        margin: 0 0 6px;
        font-size: .92rem;
    }

    .suggestion-item p {
        margin: 0;
        color: var(--muted);
        font-size: .8rem;
    }

    .share-box h3 {
        margin: 0 0 6px;
    }

    .share-box p {
        margin: 0;
        color: var(--muted);
    }

    @@media (max-width: 1080px) {
        .hero,
        .welcome-card,
        .grid-two {
            grid-template-columns: 1fr;
        }

        .trust-strip,
        .places-grid,
        .flow-grid,
        .famous-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .suggestion-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .landing-header,
        .dashboard-top {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .food-grid,
        .trust-strip,
        .places-grid,
        .flow-grid,
        .famous-grid {
            grid-template-columns: 1fr;
        }
    }

    @@keyframes floaty {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes drift {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-8px) rotate(8deg); }
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>
