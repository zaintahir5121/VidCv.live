    .hero-kicker {
        letter-spacing: 0.18em;
        font-size: 0.72rem;
        opacity: 0.9;
    }

    .hero-section h1 {
        font-size: clamp(2rem, 7vw, 3rem);
        margin: 10px 0 12px;
        line-height: 1.1;
    }

    .hero-sub {
        margin: 0;
        color: rgba(255, 255, 255, 0.9);
        max-width: 520px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .hero-note {
        margin-top: 16px;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .cta-btn {
        border: 0;
        border-radius: 999px;
        padding: 12px 20px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .cta-btn:hover {
        transform: translateY(-1px);
    }

    .cta-btn.primary {
        background: #fff;
        color: #3f31dd;
    }

    .cta-btn.ghost {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.7);
