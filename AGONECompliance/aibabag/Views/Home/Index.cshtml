    }

    .muted {
        color: #6f779f;
        margin: 2px 0 0;
    }

    .modal {
        position: fixed;
        inset: 0;
        background: rgba(16, 14, 36, 0.62);
        display: grid;
        place-items: center;
        padding: 16px;
        z-index: 20;
    }

    .modal-card {
        width: min(540px, 100%);
        border-radius: 24px;
        background: #fff;
        border: 1px solid #e7eafe;
        padding: 20px;
        text-align: center;
    }

    .modal-card h3 {
        margin-top: 0;
    }

    .modal-card p {
        color: #656d98;
        line-height: 1.5;
    }

    .camera-video {
        width: 100%;
        border-radius: 16px;
        margin: 10px 0 8px;
        background: #11172b;
        min-height: 220px;
        object-fit: cover;
    }

    .countdown {
        font-size: 2.4rem;
        font-weight: 800;
        color: #4b41e6;
        margin: 8px 0;
    }

    .modal-actions {
        display: flex;
        gap: 8px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .hidden {
        display: none !important;
    }

    @media (max-width: 740px) {
        .welcome {
            grid-template-columns: auto 1fr;
        }

        .insight-cards,
        .snapshot-grid {
            grid-template-columns: 1fr;
        }

        .hero-section {
            padding: 34px 18px;
            border-radius: 24px;
        }
    }
</style>
