@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@{
    ViewData["Title"] = "AIBABAG";
    var isLocalMode = HostingEnvironment.IsDevelopment().ToString().ToLowerInvariant();
}

<div class="onepage-shell">
    <section class="hero-report">
        <div class="hero-left">
            <p class="kicker">AIBABAG COSMIC REPORT</p>
            <h1>Discover your cosmic personality ✨</h1>
            <p class="sub">
                A playful one-page report experience with mood capture, astrology cards, and share-ready moments.
            </p>
            <div class="hero-actions">
                <button id="googleBtn" class="btn primary">Continue with Google</button>
                <button id="guestBtn" class="btn ghost">Try as Guest</button>
            </div>
            <p class="note">Just for fun. No biometrics. No image storage.</p>
        </div>
        <aside class="hero-camera-stage">
            <div class="camera-header">
                <span>Cosmic Mood Capture</span>
                <small>Optional</small>
            </div>
            <video id="cameraVideo" autoplay playsinline muted></video>
            <div class="camera-controls">
                <button id="captureVibeBtn" class="btn mini">Capture vibe ✨</button>
                <button id="skipVibeBtn" class="btn mini ghost">Skip</button>
            </div>
            <div id="countdown" class="countdown hidden">3</div>
            <p class="camera-note">Camera opens only if you tap capture.</p>
        </aside>
    </section>

    <main id="report" class="report-stack">
        <section class="card welcome">
            <div class="avatar-wrap">
                <img id="avatarImage" class="avatar hidden" alt="Profile avatar" />
                <div id="avatarFallback" class="avatar-fallback"></div>
            </div>
            <div>
                <h2 id="welcomeTitle">Hey there 👋</h2>
                <p>The universe has thoughts about you.</p>
            </div>
            <div class="top-actions">
                <button id="logoutBtn" class="btn mini ghost hidden">Logout</button>
            </div>
        </section>

        <section class="card mood">
            <p class="section-tag">TODAY'S COSMIC MOOD</p>
            <h3 id="moodTitle">🌞 Radiant Energy</h3>
            <p id="moodLine">You look like the main character and the soundtrack at the same time.</p>
            <small>Just for fun — no emotional or medical claims.</small>
        </section>

        <section class="card">
            <p class="section-tag">ASTRO SNAPSHOT</p>
            <div id="snapshotGrid" class="grid-4"></div>
        </section>

        <section class="card spirit">
            <p class="section-tag">SPIRIT ANIMAL</p>
            <h3 id="spiritAnimalTitle">🦊 Chill Fox</h3>
            <p id="spiritAnimalLine">Clever, observant, pretending not to care.</p>
        </section>

        <section class="card">
            <p class="section-tag">🎂 You share a birthday with legends</p>
            <div id="birthdayCards" class="horizontal"></div>
        </section>

        <section class="card">
            <p class="section-tag">PERSONALITY INSIGHTS</p>
            <div id="insightCards" class="grid-3"></div>
        </section>

        <section class="card share">
            <p class="section-tag">SHARE MOMENT</p>
            <div id="sharePreview" class="share-preview">
                I just discovered my cosmic personality ✨ <br />
                Aibabag
            </div>
            <div class="hero-actions">
                <button id="shareImageBtn" class="btn primary">Share image</button>
                <button id="copyLinkBtn" class="btn ghost">Copy link</button>
                <button id="downloadBtn" class="btn ghost">Download</button>
            </div>
        </section>

        <section class="card">
            <p class="section-tag">COSMIC MEMORY LANE</p>
            <div id="historyCards" class="horizontal"></div>
        </section>
    </main>
</div>

<script>
    const IS_LOCAL_MODE = @Html.Raw(isLocalMode);
    const HISTORY_KEY = "aibabag-history-v2";
    const MOODS = [
        "🌞 Radiant Energy",
        "🌊 Calm Energy",
        "⚡ Expressive Energy",
        "🌙 Reflective Energy",
        "🔥 Intense Energy"
    ];

    const state = {
        userId: null,
        profile: null,
        mood: "🌞 Radiant Energy",
        history: [],
        stream: null,
        generated: null
    };

    const ui = {
        googleBtn: document.getElementById("googleBtn"),
        guestBtn: document.getElementById("guestBtn"),
        captureVibeBtn: document.getElementById("captureVibeBtn"),
        skipVibeBtn: document.getElementById("skipVibeBtn"),
        countdown: document.getElementById("countdown"),
        cameraVideo: document.getElementById("cameraVideo"),
        avatarImage: document.getElementById("avatarImage"),
        avatarFallback: document.getElementById("avatarFallback"),
        logoutBtn: document.getElementById("logoutBtn"),
        welcomeTitle: document.getElementById("welcomeTitle"),
        moodTitle: document.getElementById("moodTitle"),
        moodLine: document.getElementById("moodLine"),
        spiritAnimalTitle: document.getElementById("spiritAnimalTitle"),
        spiritAnimalLine: document.getElementById("spiritAnimalLine"),
        snapshotGrid: document.getElementById("snapshotGrid"),
        birthdayCards: document.getElementById("birthdayCards"),
        insightCards: document.getElementById("insightCards"),
        sharePreview: document.getElementById("sharePreview"),
        shareImageBtn: document.getElementById("shareImageBtn"),
        copyLinkBtn: document.getElementById("copyLinkBtn"),
        downloadBtn: document.getElementById("downloadBtn"),
        historyCards: document.getElementById("historyCards")
    };

    init();

    async function init() {
        bindEvents();
        if (!IS_LOCAL_MODE) {
            ui.guestBtn.classList.add("hidden");
        }
        loadHistory();
        const isAuthed = await hydrateAuth();
        if (!isAuthed) {
            startGuestMode();
        }
        renderHistory();
    }

    function bindEvents() {
        ui.googleBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/login?returnUrl=/";
        });
        ui.guestBtn.addEventListener("click", startGuestMode);
        ui.captureVibeBtn.addEventListener("click", captureVibeFlow);
        ui.skipVibeBtn.addEventListener("click", skipVibeFlow);
        ui.logoutBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/logout";
        });
        ui.shareImageBtn.addEventListener("click", shareImage);
        ui.copyLinkBtn.addEventListener("click", copyLink);
        ui.downloadBtn.addEventListener("click", downloadCard);
    }

    async function hydrateAuth() {
        try {
            const res = await fetch("/api/auth/status");
            const auth = await res.json();
            if (!auth?.isAuthenticated) {
                return false;
            }

            state.userId = auth.userId;
            const googleDob = await fetchGoogleBirthday();
            state.profile = {
                name: auth.userName || "Cosmic Human",
                dateOfBirth: googleDob || auth.dateOfBirth || randomDateString(),
                avatar: auth.profileImageUrl || "",
                isGuest: false
            };
            ui.logoutBtn.classList.remove("hidden");
            await loadServerHistory();
            renderProfile();
            await skipVibeFlow();
            return true;
        } catch {
            return false;
        }
    }

    function startGuestMode() {
        state.profile = {
            name: randomItem(["Luna Spark", "Nova Bloom", "Solar Jinx", "Astra Vibe", "Mira Orbit"]),
            dateOfBirth: randomDateString(),
            avatar: "",
            isGuest: true
        };
        renderProfile();
        skipVibeFlow();
    }

    function renderProfile() {
        ui.welcomeTitle.textContent = `Hey ${state.profile.name} 👋`;
        if (state.profile.avatar) {
            ui.avatarImage.src = state.profile.avatar;
            ui.avatarImage.classList.remove("hidden");
            ui.avatarFallback.classList.add("hidden");
        } else {
            ui.avatarImage.classList.add("hidden");
            ui.avatarFallback.classList.remove("hidden");
            ui.avatarFallback.textContent = initials(state.profile.name);
        }
    }

    async function fetchGoogleBirthday() {
        try {
            const response = await fetch("/api/auth/google-birthday");
            if (!response.ok) return null;
            const payload = await response.json();
            return payload?.birthDate ? String(payload.birthDate).slice(0, 10) : null;
        } catch {
            return null;
        }
    }

    async function skipVibeFlow() {
        state.mood = randomItem(MOODS);
        await generateAndRender();
    }

    async function captureVibeFlow() {
        if (!navigator.mediaDevices?.getUserMedia) {
            await skipVibeFlow();
            return;
        }

        try {
            state.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
            ui.cameraVideo.srcObject = state.stream;
            await runCountdown();
            state.mood = captureMoodLabel(ui.cameraVideo);
            stopCamera();
            await generateAndRender();
        } catch {
            stopCamera();
            await skipVibeFlow();
        }
    }

    function stopCamera() {
        if (!state.stream) return;
        for (const track of state.stream.getTracks()) {
            track.stop();
        }
        state.stream = null;
        ui.cameraVideo.srcObject = null;
    }

    async function runCountdown() {
        ui.countdown.classList.remove("hidden");
        for (const n of [3, 2, 1]) {
            ui.countdown.textContent = String(n);
            await delay(450);
        }
        ui.countdown.classList.add("hidden");
    }

    function captureMoodLabel(video) {
        const canvas = document.createElement("canvas");
        canvas.width = video.videoWidth || 480;
        canvas.height = video.videoHeight || 320;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        const pixel = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
        let score = 0;
        for (let i = 0; i < pixel.length; i += 64) {
            score += pixel[i] + pixel[i + 1] + pixel[i + 2];
        }
        return MOODS[Math.floor(score) % MOODS.length];
    }

    async function generateAndRender() {
        const zodiac = zodiacFromDate(state.profile.dateOfBirth);
        const chinese = chineseZodiacFromDate(state.profile.dateOfBirth);
        const element = elementFromZodiac(zodiac);
        const spirit = spiritAnimal(zodiac, state.mood);
        const famous = birthdayLegends(state.profile.dateOfBirth);
        const lines = personalityLines(zodiac, state.mood);

        if (!state.profile.isGuest && state.userId) {
            try {
                await fetch("/api/insights/generate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ dateOfBirth: state.profile.dateOfBirth, photoHint: state.mood })
                });
            } catch {
                // keep local render path
            }
        }

        state.generated = {
            createdAt: new Date().toISOString(),
            zodiac,
            chinese,
            element,
            spirit,
            lines,
            famous
        };

        renderCards();
        persistHistory();
    }

    function renderCards() {
        const g = state.generated;
        ui.moodTitle.textContent = state.mood;
        ui.moodLine.textContent = moodOneLiner(state.mood);
        ui.snapshotGrid.innerHTML = [
            ["♈", "Zodiac", g.zodiac],
            ["🐉", "Chinese Zodiac", g.chinese],
            ["🔥", "Element", g.element],
            ["✨", "Destiny Vibe", destinyVibe(g.zodiac)]
        ].map(([emoji, title, value]) => `<article class="snap"><p>${emoji} ${title}</p><h4>${value}</h4></article>`).join("");

        ui.spiritAnimalTitle.textContent = `${g.spirit.emoji} Spirit Animal Today: ${g.spirit.name}`;
        ui.spiritAnimalLine.textContent = g.spirit.line;

        ui.birthdayCards.innerHTML = g.famous.map(p => `
            <article class="legend-card">
                <div class="legend-photo">${p.photo}</div>
                <h4>${escapeHtml(p.name)}</h4>
                <p>${escapeHtml(p.trait)}</p>
            </article>`).join("");

        ui.insightCards.innerHTML = [
            ["💡 Hidden strength", g.lines.hiddenStrength],
            ["🌪 Chaos trait", g.lines.chaosTrait],
            ["😶 Misunderstood", g.lines.misunderstood]
        ].map(([t, v]) => `<article class="insight"><h4>${t}</h4><p>${escapeHtml(v)}</p></article>`).join("");

        ui.sharePreview.innerHTML =
            `I just discovered my cosmic personality ✨<br/>${escapeHtml(state.profile.name)} • ${escapeHtml(state.mood)} • ${escapeHtml(g.zodiac)}<br/>Aibabag`;
    }

    function persistHistory() {
        const item = {
            id: crypto.randomUUID(),
            at: state.generated.createdAt,
            mood: state.mood,
            zodiac: state.generated.zodiac,
            name: state.profile.name,
            line: state.generated.lines.hiddenStrength
        };
        state.history = dedupe([item, ...state.history]).slice(0, 12);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        renderHistory();
    }

    function loadHistory() {
        try {
            const raw = localStorage.getItem(HISTORY_KEY);
            state.history = raw ? JSON.parse(raw) : [];
        } catch {
            state.history = [];
        }
    }

    async function loadServerHistory() {
        if (!state.userId || state.profile?.isGuest) return;
        try {
            const res = await fetch("/api/insights/history");
            if (!res.ok) return;
            const payload = await res.json();
            if (!payload?.success || !Array.isArray(payload.history)) return;
            const mapped = payload.history.map(h => ({
                id: `srv-${h.id}`,
                at: h.calculatedAt || new Date().toISOString(),
                mood: h.luckyColor ? `✨ ${h.luckyColor}` : "✨ Cosmic Energy",
                zodiac: h.zodiacSign || "Unknown",
                name: state.profile.name,
                line: h.personalityTraits || h.careerInsights || "Cosmic memory unlocked."
            }));
            state.history = dedupe([...mapped, ...state.history]).slice(0, 12);
            localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        } catch {
            // local fallback
        }
    }

    function renderHistory() {
        if (!state.history.length) {
            ui.historyCards.innerHTML = `<article class="memory-card">Your next cosmic read appears here ✨</article>`;
            return;
        }
        ui.historyCards.innerHTML = state.history.map(h => `
            <article class="memory-card">
                <h4>${escapeHtml(h.mood)}</h4>
                <p>${escapeHtml(h.name)} • ${escapeHtml(h.zodiac)}</p>
                <small>${escapeHtml(h.line)}</small>
            </article>`).join("");
    }

    async function shareImage() {
        const blob = await createShareBlob();
        if (!blob) return;
        const file = new File([blob], "aibabag-share.png", { type: "image/png" });
        if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({ files: [file], title: "AIBABAG", text: "I just discovered my cosmic personality ✨" });
            return;
        }
        await copyLink();
    }

    async function copyLink() {
        await navigator.clipboard.writeText(window.location.href);
    }

    async function downloadCard() {
        const blob = await createShareBlob();
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "aibabag-cosmic-share.png";
        a.click();
        URL.revokeObjectURL(url);
    }

    async function createShareBlob() {
        if (!state.generated) return null;
        const canvas = document.createElement("canvas");
        canvas.width = 1080;
        canvas.height = 1080;
        const ctx = canvas.getContext("2d");
        const grad = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
        grad.addColorStop(0, "#4e38ff");
        grad.addColorStop(0.5, "#8f4aff");
        grad.addColorStop(1, "#ff6fa4");
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "rgba(255,255,255,0.95)";
        ctx.fillRect(80, 120, 920, 820);
        ctx.fillStyle = "#20234f";
        ctx.font = "700 56px Inter, sans-serif";
        ctx.fillText("I discovered my cosmic personality ✨", 120, 250);
        ctx.font = "500 42px Inter, sans-serif";
        ctx.fillText(`${state.profile.name} • ${state.generated.zodiac}`, 120, 360);
        ctx.fillText(`${state.mood}`, 120, 430);
        ctx.font = "700 52px Inter, sans-serif";
        ctx.fillText("AIBABAG", 120, 820);
        return new Promise(resolve => canvas.toBlob(resolve, "image/png"));
    }

    function zodiacFromDate(dateText) {
        const d = new Date(dateText);
        const m = d.getMonth() + 1;
        const day = d.getDate();
        if ((m === 3 && day >= 21) || (m === 4 && day <= 19)) return "Aries";
        if ((m === 4 && day >= 20) || (m === 5 && day <= 20)) return "Taurus";
        if ((m === 5 && day >= 21) || (m === 6 && day <= 20)) return "Gemini";
        if ((m === 6 && day >= 21) || (m === 7 && day <= 22)) return "Cancer";
        if ((m === 7 && day >= 23) || (m === 8 && day <= 22)) return "Leo";
        if ((m === 8 && day >= 23) || (m === 9 && day <= 22)) return "Virgo";
        if ((m === 9 && day >= 23) || (m === 10 && day <= 22)) return "Libra";
        if ((m === 10 && day >= 23) || (m === 11 && day <= 21)) return "Scorpio";
        if ((m === 11 && day >= 22) || (m === 12 && day <= 21)) return "Sagittarius";
        if ((m === 12 && day >= 22) || (m === 1 && day <= 19)) return "Capricorn";
        if ((m === 1 && day >= 20) || (m === 2 && day <= 18)) return "Aquarius";
        return "Pisces";
    }

    function chineseZodiacFromDate(dateText) {
        const animals = ["Rat", "Ox", "Tiger", "Rabbit", "Dragon", "Snake", "Horse", "Goat", "Monkey", "Rooster", "Dog", "Pig"];
        const y = new Date(dateText).getFullYear();
        return animals[(y - 1900) % 12];
    }

    function elementFromZodiac(z) {
        if (["Aries", "Leo", "Sagittarius"].includes(z)) return "Fire";
        if (["Taurus", "Virgo", "Capricorn"].includes(z)) return "Earth";
        if (["Gemini", "Libra", "Aquarius"].includes(z)) return "Air";
        return "Water";
    }

    function destinyVibe(z) {
        const map = {
            Aries: "You text destiny first.",
            Taurus: "Luxury, then world domination.",
            Gemini: "Multiplayer brain mode.",
            Cancer: "Soft voice, sharp instincts.",
            Leo: "Main-character charisma.",
            Virgo: "Precision with sparkle.",
            Libra: "Style with strategy.",
            Scorpio: "Magnetic mystery.",
            Sagittarius: "Adventure + truth bombs.",
            Capricorn: "Quiet premium ambition.",
            Aquarius: "Future-minded rebel.",
            Pisces: "Dreamy creative chaos."
        };
        return map[z] || "Cosmic wildcard";
    }

    function spiritAnimal(zodiac, mood) {
        const picks = {
            "🌞 Radiant Energy": { emoji: "🦁", name: "Solar Lion", line: "Room-entry soundtrack energy." },
            "🌊 Calm Energy": { emoji: "🦦", name: "Peace Otter", line: "Calm outside, strategic inside." },
            "⚡ Expressive Energy": { emoji: "🦜", name: "Electric Parrot", line: "Colorful thoughts. Zero boring lines." },
            "🌙 Reflective Energy": { emoji: "🦊", name: "Night Fox", line: "Quiet face, dangerous intuition." },
            "🔥 Intense Energy": { emoji: "🐅", name: "Wild Tiger", line: "Focused fire with polite chaos." }
        };
        return picks[mood] || picks["🌞 Radiant Energy"];
    }

    function birthdayLegends(dateText) {
        const key = String(dateText).slice(5);
        const map = {
            "01-17": [
                { photo: "🎤", name: "Legend Singer", trait: "Known for dangerous creativity." },
                { photo: "🎬", name: "Iconic Actor", trait: "Turns drama into memes." }
            ],
            "06-01": [
                { photo: "⚽", name: "Famous Athlete", trait: "Competitive with calm confidence." },
                { photo: "🎧", name: "Top Producer", trait: "Makes chaos sound expensive." }
            ]
        };
        return map[key] || [
            { photo: "🎭", name: "Global Entertainer", trait: "Instant scene-stealing presence." },
            { photo: "🚀", name: "Visionary Founder", trait: "Builds wild ideas before lunch." },
            { photo: "🎨", name: "Creative Icon", trait: "Minimal effort, maximum style." }
        ];
    }

    function personalityLines(zodiac, mood) {
        return {
            hiddenStrength: `${zodiac} power move: cool face, wild strategy.`,
            chaosTrait: "You call it spontaneity. Your calendar calls it performance art.",
            misunderstood: "People think you're chill. You are in premium planning mode."
        };
    }

    function moodOneLiner(mood) {
        const lines = {
            "🌞 Radiant Energy": "Bright aura. Plants would grow faster around you.",
            "🌊 Calm Energy": "Calm ocean energy. Your peace scares your enemies.",
            "⚡ Expressive Energy": "Electric vibe. Your personality has subtitles.",
            "🌙 Reflective Energy": "Moonlit energy. Deep thoughts, soft voice.",
            "🔥 Intense Energy": "Fire mode. Politely unstoppable today."
        };
        return lines[mood] || "Cosmic sparkle detected.";
    }

    function dedupe(items) {
        const seen = new Set();
        return items.filter(item => {
            const key = `${item.at}|${item.mood}|${item.zodiac}|${item.line}`;
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
    }

    function randomDateString() {
        const year = 1990 + Math.floor(Math.random() * 15);
        const month = 1 + Math.floor(Math.random() * 12);
        const day = 1 + Math.floor(Math.random() * 28);
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
    }

    function randomItem(items) {
        return items[Math.floor(Math.random() * items.length)];
    }

    function initials(name) {
        return String(name).split(" ").map(x => x[0]).join("").slice(0, 2).toUpperCase();
    }

    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function escapeHtml(text) {
        return String(text)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }
</script>

<style>
    :root {
        --ink: #161833;
        --muted: #6e7399;
        --panel: #ffffff;
        --line: #e4e7fb;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, "Segoe UI", sans-serif;
        color: var(--ink);
        background: #f4f6ff;
    }

    .onepage-shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 20px 16px 70px;
    }

    .hero-report {
        background: linear-gradient(135deg, #4f3dff 0%, #7f45ff 42%, #f765a4 100%);
        border-radius: 28px;
        color: #fff;
        padding: 24px;
        display: grid;
        grid-template-columns: 1.35fr 0.95fr;
        gap: 16px;
        box-shadow: 0 18px 46px rgba(73, 53, 170, 0.35);
    }

    .kicker {
        letter-spacing: 0.18em;
        font-size: 0.72rem;
        margin: 0 0 8px;
        opacity: 0.9;
    }

    .hero-left h1 {
        margin: 0 0 10px;
        font-size: clamp(1.9rem, 5vw, 2.8rem);
    }

    .sub {
        margin: 0;
        color: rgba(255, 255, 255, 0.9);
    }

    .hero-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .note {
        font-size: 0.82rem;
        margin-top: 12px;
        color: rgba(255, 255, 255, 0.9);
    }

    .hero-camera-stage {
        background: rgba(255, 255, 255, 0.16);
        border: 1px solid rgba(255, 255, 255, 0.34);
        border-radius: 18px;
        padding: 12px;
    }

    .camera-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.86rem;
    }

    #cameraVideo {
        width: 100%;
        min-height: 220px;
        border-radius: 12px;
        background: rgba(10, 13, 35, 0.75);
        object-fit: cover;
    }

    .camera-controls {
        display: flex;
        gap: 8px;
        margin-top: 10px;
    }

    .camera-note {
        margin: 8px 0 0;
        font-size: 0.76rem;
