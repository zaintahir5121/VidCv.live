@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@{
    ViewData["Title"] = "AIBABAG";
    var isLocalMode = HostingEnvironment.IsDevelopment().ToString().ToLowerInvariant();
}

<div class="simple-shell">
    <section class="top-card">
        <div class="top-title">
            <p class="tiny">AIBABAG</p>
            <h1>Your simple cosmic report ✨</h1>
            <p class="muted">Famous personalities by your birth date + visual cards for spirit animal, best friend, and lucky fruit/veggie.</p>
        </div>
        <div class="top-actions">
            <button id="googleBtn" class="btn primary">Google Login</button>
            <button id="guestBtn" class="btn soft">Guest</button>
            <button id="logoutBtn" class="btn soft hidden">Logout</button>
        </div>
    </section>

    <section class="profile-card">
        <div class="profile-left">
            <img id="avatarImage" class="avatar hidden" alt="Profile photo" />
            <div id="avatarFallback" class="avatar-fallback"></div>
            <div>
                <h2 id="welcomeTitle">Hey Cosmic Friend 👋</h2>
                <p id="profileLine" class="muted">Your report loads instantly.</p>
            </div>
        </div>
        <div class="camera-box">
            <video id="cameraVideo" autoplay playsinline muted class="hidden"></video>
            <div id="countdown" class="countdown hidden">3</div>
            <div class="camera-actions">
                <button id="captureVibeBtn" class="btn soft">Capture Mood</button>
                <button id="skipVibeBtn" class="btn soft">Skip</button>
            </div>
            <small>Camera is optional and nothing is stored.</small>
        </div>
    </section>

    <section class="mini-grid">
        <article class="mini-card">
            <p class="tiny">MOOD</p>
            <h3 id="moodTitle">🌞 Radiant Energy</h3>
            <p id="moodLine" class="muted">Bright aura today.</p>
        </article>
        <article class="mini-card">
            <p class="tiny">ZODIAC</p>
            <h3 id="zodiacValue">Aries</h3>
            <p id="snapshotLine" class="muted">Element + destiny vibe.</p>
        </article>
    </section>

    <section class="card-section">
        <div class="section-head">
            <h3>🎂 Famous personalities born on your day</h3>
        </div>
        <div id="birthdayCards" class="photo-grid"></div>
    </section>

    <section class="card-section three-up">
        <article class="visual-card">
            <img id="spiritImage" alt="Spirit animal image" />
            <div class="visual-body">
                <p class="tiny">SPIRIT ANIMAL</p>
                <h4 id="spiritTitle">Fox</h4>
                <p id="spiritLine" class="muted">Calm and clever.</p>
            </div>
        </article>
        <article class="visual-card">
            <img id="friendImage" alt="Best friend vibe image" />
            <div class="visual-body">
                <p class="tiny">BEST FRIEND VIBE</p>
                <h4 id="friendTitle">Golden Retriever Friend</h4>
                <p id="friendLine" class="muted">Supportive and playful.</p>
            </div>
        </article>
        <article class="visual-card">
            <img id="fruitImage" alt="Lucky fruit and veggie image" />
            <div class="visual-body">
                <p class="tiny">LUCKY FRUIT / VEGGIE</p>
                <h4 id="fruitTitle">Mango + Carrot</h4>
                <p id="fruitLine" class="muted">Sweet confidence + grounded focus.</p>
            </div>
        </article>
    </section>

    <section class="card-section">
        <div class="section-head">
            <h3>Share this report</h3>
        </div>
        <div id="sharePreview" class="share-preview">I discovered my cosmic personality ✨</div>
        <div class="top-actions">
            <button id="shareImageBtn" class="btn primary">Share image</button>
            <button id="copyLinkBtn" class="btn soft">Copy link</button>
            <button id="downloadBtn" class="btn soft">Download</button>
        </div>
    </section>

    <section class="card-section">
        <div class="section-head">
            <h3>Recent cosmic history</h3>
        </div>
        <div id="historyCards" class="history-grid"></div>
    </section>
</div>

<script>
    const IS_LOCAL_MODE = @Html.Raw(isLocalMode);
    const HISTORY_KEY = "aibabag-history-v3";
    const MOODS = ["🌞 Radiant Energy", "🌊 Calm Energy", "⚡ Expressive Energy", "🌙 Reflective Energy", "🔥 Intense Energy"];

    const state = {
        userId: null,
        profile: null,
        mood: "🌞 Radiant Energy",
        history: [],
        stream: null,
        generated: null
    };

    const ui = {
        googleBtn: document.getElementById("googleBtn"),
        guestBtn: document.getElementById("guestBtn"),
        logoutBtn: document.getElementById("logoutBtn"),
        avatarImage: document.getElementById("avatarImage"),
        avatarFallback: document.getElementById("avatarFallback"),
        welcomeTitle: document.getElementById("welcomeTitle"),
        profileLine: document.getElementById("profileLine"),
        captureVibeBtn: document.getElementById("captureVibeBtn"),
        skipVibeBtn: document.getElementById("skipVibeBtn"),
        cameraVideo: document.getElementById("cameraVideo"),
        countdown: document.getElementById("countdown"),
        moodTitle: document.getElementById("moodTitle"),
        moodLine: document.getElementById("moodLine"),
        zodiacValue: document.getElementById("zodiacValue"),
        snapshotLine: document.getElementById("snapshotLine"),
        birthdayCards: document.getElementById("birthdayCards"),
        spiritImage: document.getElementById("spiritImage"),
        spiritTitle: document.getElementById("spiritTitle"),
        spiritLine: document.getElementById("spiritLine"),
        friendImage: document.getElementById("friendImage"),
        friendTitle: document.getElementById("friendTitle"),
        friendLine: document.getElementById("friendLine"),
        fruitImage: document.getElementById("fruitImage"),
        fruitTitle: document.getElementById("fruitTitle"),
        fruitLine: document.getElementById("fruitLine"),
        sharePreview: document.getElementById("sharePreview"),
        shareImageBtn: document.getElementById("shareImageBtn"),
        copyLinkBtn: document.getElementById("copyLinkBtn"),
        downloadBtn: document.getElementById("downloadBtn"),
        historyCards: document.getElementById("historyCards")
    };

    init();

    async function init() {
        bindEvents();
        if (!IS_LOCAL_MODE) {
            ui.guestBtn.classList.add("hidden");
        }

        loadHistory();
        const isAuthed = await hydrateAuth();
        if (!isAuthed) {
            startGuestMode();
        }

        renderHistory();
    }

    function bindEvents() {
        ui.googleBtn.addEventListener("click", () => window.location.href = "/api/auth/login?returnUrl=/");
        ui.guestBtn.addEventListener("click", startGuestMode);
        ui.logoutBtn.addEventListener("click", () => window.location.href = "/api/auth/logout");
        ui.captureVibeBtn.addEventListener("click", captureVibeFlow);
        ui.skipVibeBtn.addEventListener("click", skipVibeFlow);
        ui.shareImageBtn.addEventListener("click", shareImage);
        ui.copyLinkBtn.addEventListener("click", copyLink);
        ui.downloadBtn.addEventListener("click", downloadCard);
    }

    async function hydrateAuth() {
        try {
            const response = await fetch("/api/auth/status");
            if (!response.ok) return false;
            const auth = await response.json();
            if (!auth?.isAuthenticated) return false;

            state.userId = auth.userId;
            const dobFromGoogle = await fetchGoogleBirthday();
            state.profile = {
                name: auth.userName || "Cosmic Human",
                dateOfBirth: dobFromGoogle || auth.dateOfBirth || randomDateString(),
                avatar: auth.profileImageUrl || "",
                isGuest: false
            };

            ui.logoutBtn.classList.remove("hidden");
            renderProfile();
            await loadServerHistory();
            await skipVibeFlow();
            return true;
        } catch {
            return false;
        }
    }

    function startGuestMode() {
        state.profile = {
            name: randomItem(["Luna Spark", "Nova Bloom", "Astra Flow", "Mira Glow"]),
            dateOfBirth: randomDateString(),
            avatar: "",
            isGuest: true
        };
        renderProfile();
        skipVibeFlow();
    }

    function renderProfile() {
        ui.welcomeTitle.textContent = `Hey ${state.profile.name} 👋`;
        ui.profileLine.textContent = `DOB: ${state.profile.dateOfBirth} • Simple visual report mode`;

        if (state.profile.avatar) {
            ui.avatarImage.src = state.profile.avatar;
            ui.avatarImage.classList.remove("hidden");
            ui.avatarFallback.classList.add("hidden");
        } else {
            ui.avatarImage.classList.add("hidden");
            ui.avatarFallback.classList.remove("hidden");
            ui.avatarFallback.textContent = initials(state.profile.name);
        }
    }

    async function fetchGoogleBirthday() {
        try {
            const response = await fetch("/api/auth/google-birthday");
            if (!response.ok) return null;
            const payload = await response.json();
            return payload?.birthDate ? String(payload.birthDate).slice(0, 10) : null;
        } catch {
            return null;
        }
    }

    async function skipVibeFlow() {
        state.mood = randomItem(MOODS);
        await generateAndRender();
    }

    async function captureVibeFlow() {
        if (!navigator.mediaDevices?.getUserMedia) {
            await skipVibeFlow();
            return;
        }

        try {
            ui.cameraVideo.classList.remove("hidden");
            state.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" }, audio: false });
            ui.cameraVideo.srcObject = state.stream;
            await runCountdown();
            state.mood = captureMoodLabel(ui.cameraVideo);
            stopCamera();
            await generateAndRender();
        } catch {
            stopCamera();
            await skipVibeFlow();
        }
    }

    function stopCamera() {
        if (!state.stream) return;
        for (const track of state.stream.getTracks()) {
            track.stop();
        }
        state.stream = null;
        ui.cameraVideo.srcObject = null;
        ui.cameraVideo.classList.add("hidden");
    }

    async function runCountdown() {
        ui.countdown.classList.remove("hidden");
        for (const n of [3, 2, 1]) {
            ui.countdown.textContent = String(n);
            await delay(400);
        }
        ui.countdown.classList.add("hidden");
    }

    function captureMoodLabel(video) {
        const canvas = document.createElement("canvas");
        canvas.width = video.videoWidth || 320;
        canvas.height = video.videoHeight || 220;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        const pixels = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
        let score = 0;
        for (let i = 0; i < pixels.length; i += 64) {
            score += pixels[i] + pixels[i + 1] + pixels[i + 2];
        }
        return MOODS[Math.floor(score) % MOODS.length];
    }

    async function generateAndRender() {
        const zodiac = zodiacFromDate(state.profile.dateOfBirth);
        const chinese = chineseZodiacFromDate(state.profile.dateOfBirth);
        const element = elementFromZodiac(zodiac);
        const spirit = pickSpiritAnimal(state.mood);
        const bestFriend = pickBestFriend(zodiac);
        const luckyFood = pickLuckyFruitVeg(element);
        const famous = await fetchFamousPersonalities(state.profile.dateOfBirth);

        if (!state.profile.isGuest && state.userId) {
            try {
                await fetch("/api/insights/generate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ dateOfBirth: state.profile.dateOfBirth, photoHint: state.mood })
                });
            } catch {
                // Keep UX smooth even if API call fails.
            }
        }

        state.generated = {
            createdAt: new Date().toISOString(),
            zodiac,
            chinese,
            element,
            spirit,
            bestFriend,
            luckyFood,
            famous
        };

        renderCards();
        persistHistory();
    }

    async function fetchFamousPersonalities(dob) {
        try {
            const response = await fetch(`/api/insights/famous-by-birthday?dob=${encodeURIComponent(dob)}`);
            if (!response.ok) {
                return fallbackFamous();
            }

            const payload = await response.json();
            if (!payload?.success || !Array.isArray(payload.people) || !payload.people.length) {
                return fallbackFamous();
            }

            return payload.people.slice(0, 8).map(person => ({
                name: person.name || "Famous Personality",
                summary: person.summary || "Shares your birthday energy.",
                imageUrl: safeUrl(person.imageUrl, "https://upload.wikimedia.org/wikipedia/commons/6/65/No-Image-Placeholder.svg"),
                articleUrl: safeUrl(person.articleUrl, "")
            }));
        } catch {
            return fallbackFamous();
        }
    }

    function fallbackFamous() {
        return [
            {
                name: "Maya Angelou",
                summary: "Poet and storyteller with timeless voice.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/0/09/Dr._Maya_Angelou.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Maya_Angelou"
            },
            {
                name: "Gal Gadot",
                summary: "Actor with powerful screen presence.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/e/eb/Gal_Gadot_2018.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Gal_Gadot"
            },
            {
                name: "Akon",
                summary: "Singer and producer known worldwide.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/5/5d/Akon_2009.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Akon"
            }
        ];
    }

    function renderCards() {
        const g = state.generated;
        ui.moodTitle.textContent = state.mood;
        ui.moodLine.textContent = moodOneLiner(state.mood);
        ui.zodiacValue.textContent = `${g.zodiac} • ${g.chinese}`;
        ui.snapshotLine.textContent = `${g.element} sign energy • ${destinyVibe(g.zodiac)}`;

        ui.spiritImage.src = g.spirit.image;
        ui.spiritTitle.textContent = `${g.spirit.emoji} ${g.spirit.name}`;
        ui.spiritLine.textContent = g.spirit.line;

        ui.friendImage.src = g.bestFriend.image;
        ui.friendTitle.textContent = g.bestFriend.name;
        ui.friendLine.textContent = g.bestFriend.line;

        ui.fruitImage.src = g.luckyFood.image;
        ui.fruitTitle.textContent = g.luckyFood.name;
        ui.fruitLine.textContent = g.luckyFood.line;

        ui.birthdayCards.innerHTML = g.famous.map(person => `
            <article class="person-card">
                <img src="${escapeHtml(person.imageUrl)}" alt="${escapeHtml(person.name)}" loading="lazy" />
                <div class="person-body">
                    <h4>${escapeHtml(person.name)}</h4>
                    <p>${escapeHtml(person.summary)}</p>
                    ${person.articleUrl ? `<a href="${escapeHtml(person.articleUrl)}" target="_blank" rel="noreferrer noopener">View profile</a>` : ""}
                </div>
            </article>
        `).join("");

        ui.sharePreview.innerHTML = `I discovered my cosmic personality ✨<br>${escapeHtml(state.profile.name)} • ${escapeHtml(g.zodiac)} • ${escapeHtml(state.mood)}`;
    }

    function persistHistory() {
        const item = {
            id: crypto.randomUUID(),
            at: state.generated.createdAt,
            mood: state.mood,
            zodiac: state.generated.zodiac,
            line: state.generated.spirit.line
        };
        state.history = dedupe([item, ...state.history]).slice(0, 12);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        renderHistory();
    }

    function loadHistory() {
        try {
            const raw = localStorage.getItem(HISTORY_KEY);
            state.history = raw ? JSON.parse(raw) : [];
        } catch {
            state.history = [];
        }
    }

    async function loadServerHistory() {
        if (!state.userId || state.profile?.isGuest) return;
        try {
            const res = await fetch("/api/insights/history");
            if (!res.ok) return;
            const payload = await res.json();
            if (!payload?.success || !Array.isArray(payload.history)) return;

            const mapped = payload.history.map(h => ({
                id: `srv-${h.id}`,
                at: h.calculatedAt || new Date().toISOString(),
                mood: h.luckyColor ? `✨ ${h.luckyColor}` : "✨ Cosmic",
                zodiac: h.zodiacSign || "Unknown",
                line: h.personalityTraits || "Cosmic memory"
            }));

            state.history = dedupe([...mapped, ...state.history]).slice(0, 12);
            localStorage.setItem(HISTORY_KEY, JSON.stringify(state.history));
        } catch {
            // Local history only.
        }
    }

    function renderHistory() {
        if (!state.history.length) {
            ui.historyCards.innerHTML = `<article class="history-card">No history yet. Generate a mood and your cards will appear here.</article>`;
            return;
        }

        ui.historyCards.innerHTML = state.history.map(item => `
            <article class="history-card">
                <h4>${escapeHtml(item.mood)}</h4>
                <p>${escapeHtml(item.zodiac)}</p>
                <small>${escapeHtml(item.line)}</small>
            </article>
        `).join("");
    }

    async function shareImage() {
        const blob = await createShareBlob();
        if (!blob) return;
        const file = new File([blob], "aibabag-share.png", { type: "image/png" });
        if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({ files: [file], title: "AIBABAG", text: "I discovered my cosmic personality ✨" });
            return;
        }
        await copyLink();
    }

    async function copyLink() {
        await navigator.clipboard.writeText(window.location.href);
    }

    async function downloadCard() {
        const blob = await createShareBlob();
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "aibabag-cosmic-share.png";
        a.click();
        URL.revokeObjectURL(url);
    }

    async function createShareBlob() {
        if (!state.generated) return null;

        const canvas = document.createElement("canvas");
        canvas.width = 1000;
        canvas.height = 1000;
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
        gradient.addColorStop(0, "#5b45ff");
        gradient.addColorStop(1, "#f56aa8");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.fillStyle = "rgba(255,255,255,0.95)";
        ctx.fillRect(70, 100, 860, 800);
        ctx.fillStyle = "#21244f";
        ctx.font = "700 48px Inter, sans-serif";
        ctx.fillText("My Cosmic Report ✨", 120, 230);
        ctx.font = "500 36px Inter, sans-serif";
        ctx.fillText(`${state.profile.name}`, 120, 330);
        ctx.fillText(`${state.generated.zodiac} • ${state.mood}`, 120, 390);
        ctx.fillText(`${state.generated.spirit.name}`, 120, 460);
        ctx.font = "700 44px Inter, sans-serif";
        ctx.fillText("AIBABAG", 120, 780);

        return new Promise(resolve => canvas.toBlob(resolve, "image/png"));
    }

    function zodiacFromDate(dateText) {
        const d = new Date(dateText);
        const m = d.getMonth() + 1;
        const day = d.getDate();
        if ((m === 3 && day >= 21) || (m === 4 && day <= 19)) return "Aries";
        if ((m === 4 && day >= 20) || (m === 5 && day <= 20)) return "Taurus";
        if ((m === 5 && day >= 21) || (m === 6 && day <= 20)) return "Gemini";
        if ((m === 6 && day >= 21) || (m === 7 && day <= 22)) return "Cancer";
        if ((m === 7 && day >= 23) || (m === 8 && day <= 22)) return "Leo";
        if ((m === 8 && day >= 23) || (m === 9 && day <= 22)) return "Virgo";
        if ((m === 9 && day >= 23) || (m === 10 && day <= 22)) return "Libra";
        if ((m === 10 && day >= 23) || (m === 11 && day <= 21)) return "Scorpio";
        if ((m === 11 && day >= 22) || (m === 12 && day <= 21)) return "Sagittarius";
        if ((m === 12 && day >= 22) || (m === 1 && day <= 19)) return "Capricorn";
        if ((m === 1 && day >= 20) || (m === 2 && day <= 18)) return "Aquarius";
        return "Pisces";
    }

    function chineseZodiacFromDate(dateText) {
        const animals = ["Rat", "Ox", "Tiger", "Rabbit", "Dragon", "Snake", "Horse", "Goat", "Monkey", "Rooster", "Dog", "Pig"];
        const year = new Date(dateText).getFullYear();
        return animals[(year - 1900) % 12];
    }

    function elementFromZodiac(zodiac) {
        if (["Aries", "Leo", "Sagittarius"].includes(zodiac)) return "Fire";
        if (["Taurus", "Virgo", "Capricorn"].includes(zodiac)) return "Earth";
        if (["Gemini", "Libra", "Aquarius"].includes(zodiac)) return "Air";
        return "Water";
    }

    function pickSpiritAnimal(mood) {
        const map = {
            "🌞 Radiant Energy": {
                emoji: "🦁",
                name: "Solar Lion",
                line: "Confident, warm, and visible in every room.",
                image: "https://images.unsplash.com/photo-1546182990-dffeafbe841d?auto=format&fit=crop&w=900&q=80"
            },
            "🌊 Calm Energy": {
                emoji: "🦦",
                name: "Ocean Otter",
                line: "Peaceful outside, very smart inside.",
                image: "https://images.unsplash.com/photo-1564349683136-77e08dba1ef7?auto=format&fit=crop&w=900&q=80"
            },
            "⚡ Expressive Energy": {
                emoji: "🦜",
                name: "Color Parrot",
                line: "Loud ideas, bright confidence, fun chaos.",
                image: "https://images.unsplash.com/photo-1518791841217-8f162f1e1131?auto=format&fit=crop&w=900&q=80"
            },
            "🌙 Reflective Energy": {
                emoji: "🦊",
                name: "Night Fox",
                line: "Quiet face, sharp instincts.",
                image: "https://images.unsplash.com/photo-1516934024742-b461fba47600?auto=format&fit=crop&w=900&q=80"
            },
            "🔥 Intense Energy": {
                emoji: "🐅",
                name: "Wild Tiger",
                line: "Focused power with bold action.",
                image: "https://images.unsplash.com/photo-1549480017-d76466a4b7e8?auto=format&fit=crop&w=900&q=80"
            }
        };
        return map[mood] || map["🌞 Radiant Energy"];
    }

    function pickBestFriend(zodiac) {
        const map = {
            Aries: { name: "Golden Retriever Friend", line: "Always ready, always positive.", image: "https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&w=900&q=80" },
            Taurus: { name: "Panda Friend", line: "Calm loyalty and soft comfort.", image: "https://images.unsplash.com/photo-1564349683136-77e08dba1ef7?auto=format&fit=crop&w=900&q=80" },
            Gemini: { name: "Parrot Friend", line: "Talkative, witty, never boring.", image: "https://images.unsplash.com/photo-1522926193341-e9ffd686c60f?auto=format&fit=crop&w=900&q=80" },
            Cancer: { name: "Dolphin Friend", line: "Emotionally smart and playful.", image: "https://images.unsplash.com/photo-1568430462989-44163eb1752f?auto=format&fit=crop&w=900&q=80" },
            Leo: { name: "Lion Friend", line: "Protective and high-energy support.", image: "https://images.unsplash.com/photo-1614027164847-1b28cfe1df60?auto=format&fit=crop&w=900&q=80" },
            Virgo: { name: "Owl Friend", line: "Quiet advice, always correct.", image: "https://images.unsplash.com/photo-1501706362039-c6e08f4bbfff?auto=format&fit=crop&w=900&q=80" },
            Libra: { name: "Swan Friend", line: "Balanced, graceful, diplomatic.", image: "https://images.unsplash.com/photo-1518020382113-a7e8fc38eac9?auto=format&fit=crop&w=900&q=80" },
            Scorpio: { name: "Wolf Friend", line: "Deep loyalty, zero fake energy.", image: "https://images.unsplash.com/photo-1474511320723-9a56873867b5?auto=format&fit=crop&w=900&q=80" },
            Sagittarius: { name: "Horse Friend", line: "Adventure partner forever.", image: "https://images.unsplash.com/photo-1593179357196-705d543377a8?auto=format&fit=crop&w=900&q=80" },
            Capricorn: { name: "Elephant Friend", line: "Solid support, long memory.", image: "https://images.unsplash.com/photo-1557053910-d9eadeed1c58?auto=format&fit=crop&w=900&q=80" },
            Aquarius: { name: "Husky Friend", line: "Independent but always there.", image: "https://images.unsplash.com/photo-1605568427561-40dd23c2acea?auto=format&fit=crop&w=900&q=80" },
            Pisces: { name: "Sea Turtle Friend", line: "Gentle and wise companion.", image: "https://images.unsplash.com/photo-1560275619-4662e36fa65c?auto=format&fit=crop&w=900&q=80" }
        };
        return map[zodiac] || map.Aries;
    }

    function pickLuckyFruitVeg(element) {
        const map = {
            Fire: {
                name: "Mango + Chili",
                line: "Sweet confidence and bold spark.",
                image: "https://images.unsplash.com/photo-1591073113125-e46713c829ed?auto=format&fit=crop&w=900&q=80"
            },
            Earth: {
                name: "Avocado + Carrot",
                line: "Grounded energy and stable focus.",
                image: "https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=900&q=80"
            },
            Air: {
                name: "Apple + Mint",
                line: "Fresh thinking and light creativity.",
                image: "https://images.unsplash.com/photo-1567306226416-28f0efdc88ce?auto=format&fit=crop&w=900&q=80"
            },
            Water: {
                name: "Blueberry + Cucumber",
                line: "Cool mood and emotional balance.",
                image: "https://images.unsplash.com/photo-1490818387583-1baba5e638af?auto=format&fit=crop&w=900&q=80"
            }
        };
        return map[element] || map.Fire;
    }

    function destinyVibe(zodiac) {
        const map = {
            Aries: "moves first",
            Taurus: "builds steady",
            Gemini: "thinks fast",
            Cancer: "feels deep",
            Leo: "shines bright",
            Virgo: "plans smart",
            Libra: "balances all",
            Scorpio: "reads energy",
            Sagittarius: "chases adventure",
            Capricorn: "wins slowly",
            Aquarius: "creates new ideas",
            Pisces: "imagines magic"
        };
        return map[zodiac] || "cosmic";
    }

    function moodOneLiner(mood) {
        const map = {
            "🌞 Radiant Energy": "Bright energy. People notice your vibe quickly.",
            "🌊 Calm Energy": "Calm energy. Your peace is powerful.",
            "⚡ Expressive Energy": "Expressive energy. Your presence feels alive.",
            "🌙 Reflective Energy": "Reflective energy. Quiet but deeply aware.",
            "🔥 Intense Energy": "Intense energy. Focused and unstoppable."
        };
        return map[mood] || "Cosmic mood detected.";
    }

    function safeUrl(url, fallback) {
        if (!url || typeof url !== "string") return fallback;
        if (url.startsWith("http://") || url.startsWith("https://")) return url;
        return fallback;
    }

    function dedupe(items) {
        const seen = new Set();
        return items.filter(item => {
            const key = `${item.at}|${item.mood}|${item.zodiac}|${item.line}`;
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
    }

    function randomDateString() {
        const year = 1990 + Math.floor(Math.random() * 15);
        const month = 1 + Math.floor(Math.random() * 12);
        const day = 1 + Math.floor(Math.random() * 28);
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
    }

    function randomItem(items) {
        return items[Math.floor(Math.random() * items.length)];
    }

    function initials(name) {
        return String(name).split(" ").map(x => x[0]).join("").slice(0, 2).toUpperCase();
    }

    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function escapeHtml(text) {
        return String(text)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }
</script>

<style>
    :root {
        --bg: #f4f6ff;
        --panel: #ffffff;
        --line: #e4e9ff;
        --text: #1d224e;
        --muted: #66709b;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
    }

    .simple-shell {
        max-width: 1120px;
        margin: 0 auto;
        padding: 18px 14px 60px;
        display: grid;
        gap: 12px;
    }

    .top-card,
    .profile-card,
    .mini-card,
    .card-section,
    .history-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(40, 47, 109, 0.08);
    }

    .top-card {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        padding: 18px;
        background: linear-gradient(135deg, #5545ff 0%, #7955ff 45%, #f26aa5 100%);
        color: #fff;
    }

    .top-title h1 {
        margin: 0 0 6px;
        font-size: clamp(1.5rem, 4vw, 2.2rem);
    }

    .top-title .muted {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        max-width: 680px;
    }

    .top-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .profile-card {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 12px;
        padding: 14px;
    }

    .profile-left {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .avatar,
    .avatar-fallback {
        width: 64px;
        height: 64px;
        border-radius: 16px;
    }

    .avatar {
        object-fit: cover;
    }

    .avatar-fallback {
        background: linear-gradient(140deg, #5b45ff, #f26aa5);
        display: grid;
        place-items: center;
        font-weight: 700;
        color: #fff;
    }

    .camera-box {
        border: 1px dashed var(--line);
        border-radius: 14px;
        padding: 10px;
        background: #fcfdff;
    }

    .camera-box video {
        width: 100%;
        max-height: 170px;
        border-radius: 10px;
        object-fit: cover;
        margin-bottom: 8px;
        background: #151934;
    }

    .camera-actions {
        display: flex;
        gap: 8px;
        margin-bottom: 6px;
    }

    .countdown {
        font-size: 1.8rem;
        font-weight: 800;
        text-align: center;
    }

    .mini-grid {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mini-card {
        padding: 14px;
    }

    .mini-card h3 {
        margin: 4px 0 6px;
    }

    .card-section {
        padding: 14px;
    }

    .section-head h3 {
        margin: 0 0 10px;
        font-size: 1.12rem;
    }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 10px;
    }

    .person-card {
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        background: #fcfdff;
    }

    .person-card img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        display: block;
        background: #edf0ff;
    }

    .person-body {
        padding: 10px;
        display: grid;
        gap: 6px;
    }

    .person-body h4 {
        margin: 0;
    }

    .person-body p {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .person-body a {
        color: #4d44eb;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .three-up {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .visual-card {
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        background: #fcfdff;
    }

    .visual-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
    }

    .visual-body {
        padding: 10px;
    }

    .visual-body h4 {
        margin: 5px 0;
    }

    .visual-body p {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.4;
    }

    .share-preview {
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 10px;
        background: linear-gradient(130deg, #5948ff, #f26ca7);
        color: #fff;
        font-weight: 600;
        line-height: 1.45;
    }

    .history-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 10px;
    }

    .history-card {
        padding: 10px;
        border-radius: 12px;
        border: 1px solid var(--line);
    }

    .history-card h4 {
        margin: 0 0 6px;
        font-size: 0.95rem;
    }

    .history-card p {
        margin: 0;
        color: var(--muted);
    }

    .history-card small {
        color: var(--muted);
    }

    .btn {
        border: none;
        border-radius: 999px;
        padding: 9px 13px;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
    }

    .btn.primary {
        background: #fff;
        color: #4539e1;
    }

    .btn.soft {
        background: #f1f4ff;
        color: #2f3d8e;
        border: 1px solid #d8dfff;
    }

    .tiny {
        margin: 0;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        font-weight: 700;
        opacity: 0.85;
    }

    .muted {
        color: var(--muted);
    }

    .hidden {
        display: none !important;
    }

    @@media (max-width: 960px) {
        .top-card,
        .profile-card {
            grid-template-columns: 1fr;
            display: grid;
        }

        .three-up,
        .mini-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
