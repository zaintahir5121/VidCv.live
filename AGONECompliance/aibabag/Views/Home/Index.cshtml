        position: relative;
        overflow: hidden;
        box-shadow: 0 22px 60px rgba(77, 45, 170, 0.35);
    }

    .hero-glow {
        position: absolute;
        right: -70px;
        top: -40px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.16);
        filter: blur(4px);
