    }

    .avatar {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        object-fit: cover;
    }

    .avatar-fallback {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        background: linear-gradient(140deg, #5f4fff, #fb6ca8);
        display: grid;
        place-items: center;
        color: #fff;
        font-weight: 700;
    }

    .tiny-btn {
        border: 1px solid #ccd4ff;
        background: #f7f8ff;
        color: #2f3b88;
        border-radius: 999px;
        padding: 8px 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .section-tag {
        margin: 0 0 10px;
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        color: #7177aa;
        font-weight: 700;
    }

    .mood {
