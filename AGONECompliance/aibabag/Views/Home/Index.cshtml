@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostingEnvironment
@{
    ViewData["Title"] = "AstroAI Insight";
}

<div id="loginGate" class="login-gate">
    <div class="login-panel">
        <p class="brand-kicker">AstroAI Insight</p>
        <h1>Login with Google to view your full cosmic report</h1>
        <p class="gate-note">Google login is mandatory for this experience.</p>
        <button id="googleBtn" class="primary-btn">Continue with Google</button>
    </div>
</div>

<div id="appShell" class="astro-shell hidden">
    <header class="topbar">
        <div class="logo-block">
            <div class="logo-dot">✦</div>
            <div>
                <h1>AstroAI Insight</h1>
                <p>AI + Astrology, All About You</p>
            </div>
        </div>
        <div class="top-right">
            <div class="user-pill">
                <img id="topUserImage" class="top-user-image hidden" alt="Top user photo" />
                <div id="topUserFallback" class="top-user-fallback"></div>
                <div>
                    <p id="topUserName">Rahul Sharma</p>
                    <small id="topUserEmail">rahul@gmail.com</small>
                </div>
                <span class="pro-tag">Pro</span>
            </div>
        </div>
        <div class="top-actions">
            <button class="ghost-btn">Share Report</button>
            <button id="logoutBtn" class="ghost-btn">Logout</button>
        </div>
    </header>

    <section class="hero-grid">
        <article class="card profile-card">
            <div class="profile-photo-wrap">
                <img id="avatarImage" class="profile-photo hidden" alt="Profile photo" />
                <div id="avatarFallback" class="profile-photo-fallback"></div>
            </div>
            <div class="profile-main">
                <h2 id="welcomeTitle">Hello, Rahul! ✨</h2>
                <p id="heroLine">Here is your personalized AI + Astrology insights report.</p>
                <div class="meta-row">
                    <span id="dobBadge">15 August 1996</span>
                    <span id="timeBadge">10:30 AM</span>
                    <span id="cityBadge">New Delhi, India</span>
                </div>
            </div>
        </article>

        <article class="card signs-card">
            <h3 id="sunSign">Leo ♌</h3>
            <p>Sun Sign</p>
            <h3 id="moonSign">Taurus ♉</h3>
            <p>Moon Sign</p>
            <h3 id="ascSign">Virgo ♍</h3>
            <p>Ascendant</p>
        </article>

        <article class="card summary-card">
            <h3>Your Cosmic Summary</h3>
            <p id="cosmicSummary">You are a natural-born leader with a creative soul and a kind heart. You inspire people and love deeply.</p>
        </article>
    </section>

    <section class="insight-grid">
        <article class="insight-card">
            <img id="animalImage" alt="Animal personality" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Animal Personality</p>
                <h4 id="animalTitle">You are a Lion</h4>
                <p id="animalLine">Confident, brave and naturally protective.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="foodImage" alt="Food personality" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Food Personality</p>
                <h4 id="foodTitle">Spicy & Flavorful</h4>
                <p id="foodLine">You love excitement and variety.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="travelImage" alt="Travel personality" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Travel Personality</p>
                <h4 id="travelTitle">Explorer</h4>
                <p id="travelLine">Mountains, open skies and new paths.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="careerImage" alt="Career personality" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Career Personality</p>
                <h4 id="careerTitle">Leader</h4>
                <p id="careerLine">Best in leadership and entrepreneurship.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="loveImage" alt="Love and marriage" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Love & Marriage</p>
                <h4 id="loveTitle">Loyal Lover</h4>
                <p id="loveLine">Deep loyalty and emotional depth.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="familyImage" alt="Family and relationships" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Family & Relationships</p>
                <h4 id="familyTitle">Family Protector</h4>
                <p id="familyLine">You value harmony and loyalty.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="futureImage" alt="Children and future" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Children & Future</p>
                <h4 id="futureTitle">Bright Future</h4>
                <p id="futureLine">The future brings creative opportunities.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="moneyImage" alt="Wealth and finance" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Wealth & Finance</p>
                <h4 id="moneyTitle">Steady Growth</h4>
                <p id="moneyLine">Smart investments and consistency win.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="educationImage" alt="Education and college" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Education & College</p>
                <h4 id="educationTitle">Knowledge Builder</h4>
                <p id="educationLine">Strong learning with practical thinking.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="healthImage" alt="Health and wellness" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Health & Wellness</p>
                <h4 id="healthTitle">Mind-Body Balance</h4>
                <p id="healthLine">Meditation and routines suit you best.</p>
            </div>
        </article>

        <article class="insight-card">
            <img id="purposeImage" alt="Life purpose" />
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Life Purpose</p>
                <h4 id="purposeTitle">To Inspire</h4>
                <p id="purposeLine">Create positive impact in the world.</p>
            </div>
        </article>

        <article class="insight-card essentials">
            <div class="overlay"></div>
            <div class="insight-body">
                <p class="chip">Lucky Essentials</p>
                <ul id="luckyList">
                    <li>Lucky Color: Gold</li>
                    <li>Lucky Number: 1, 3, 9</li>
                    <li>Lucky Day: Sunday</li>
                    <li>Lucky Gem: Ruby</li>
                </ul>
            </div>
        </article>
    </section>

    <section class="card famous-section">
        <h3>Famous personalities born on your same date</h3>
        <div id="famousGrid" class="famous-grid"></div>
    </section>

    <section class="bottom-strip">
        <article class="strip-card">
            <p>AI Insight</p>
            <h4>Birth + Personality Model</h4>
        </article>
        <article class="strip-card">
            <p>Personality Score</p>
            <h4>92%</h4>
        </article>
        <article class="strip-card">
            <p>Success Potential</p>
            <h4>88%</h4>
        </article>
        <article class="strip-card">
            <p>Happiness Index</p>
            <h4>85%</h4>
        </article>
        <button class="download-btn">Download Full Report</button>
    </section>
</div>

<script>
    const state = {
        userId: null,
        profile: null,
        mood: "🌞 Radiant Energy",
        stream: null,
        famous: []
    };

    const ui = {
        loginGate: document.getElementById("loginGate"),
        appShell: document.getElementById("appShell"),
        googleBtn: document.getElementById("googleBtn"),
        logoutBtn: document.getElementById("logoutBtn"),
        avatarImage: document.getElementById("avatarImage"),
        avatarFallback: document.getElementById("avatarFallback"),
        topUserImage: document.getElementById("topUserImage"),
        topUserFallback: document.getElementById("topUserFallback"),
        topUserName: document.getElementById("topUserName"),
        topUserEmail: document.getElementById("topUserEmail"),
        welcomeTitle: document.getElementById("welcomeTitle"),
        heroLine: document.getElementById("heroLine"),
        dobBadge: document.getElementById("dobBadge"),
        timeBadge: document.getElementById("timeBadge"),
        cityBadge: document.getElementById("cityBadge"),
        sunSign: document.getElementById("sunSign"),
        moonSign: document.getElementById("moonSign"),
        ascSign: document.getElementById("ascSign"),
        cosmicSummary: document.getElementById("cosmicSummary"),
        famousGrid: document.getElementById("famousGrid"),
        luckyList: document.getElementById("luckyList")
    };

    const imageMap = {
        animalImage: "https://images.unsplash.com/photo-1546182990-dffeafbe841d?auto=format&fit=crop&w=1200&q=80",
        foodImage: "https://images.unsplash.com/photo-1627308595181-d1b5d67129c4?auto=format&fit=crop&w=1200&q=80",
        travelImage: "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80",
        careerImage: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1200&q=80",
        loveImage: "https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?auto=format&fit=crop&w=1200&q=80",
        familyImage: "https://images.unsplash.com/photo-1511895426328-dc8714191300?auto=format&fit=crop&w=1200&q=80",
        futureImage: "https://images.unsplash.com/photo-1503919005314-30d93d07d823?auto=format&fit=crop&w=1200&q=80",
        moneyImage: "https://images.unsplash.com/photo-1624969862644-791f3dc98927?auto=format&fit=crop&w=1200&q=80",
        educationImage: "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80",
        healthImage: "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=1200&q=80",
        purposeImage: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
    };

    init();

    async function init() {
        wireEvents();
        applyStaticImages();
        const authed = await hydrateAuth();
        if (!authed) {
            showGate();
            return;
        }
        showApp();
        await renderReport();
    }

    function wireEvents() {
        ui.googleBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/login?returnUrl=/";
        });
        ui.logoutBtn.addEventListener("click", () => {
            window.location.href = "/api/auth/logout";
        });
    }

    function applyStaticImages() {
        for (const [id, value] of Object.entries(imageMap)) {
            const el = document.getElementById(id);
            if (el) {
                el.src = value;
            }
        }
    }

    async function hydrateAuth() {
        try {
            const response = await fetch("/api/auth/status");
            if (!response.ok) {
                return false;
            }
            const auth = await response.json();
            if (!auth?.isAuthenticated) {
                return false;
            }

            state.userId = auth.userId;
            const dobFromGoogle = await fetchGoogleBirthday();
            state.profile = {
                name: auth.userName || "Cosmic User",
                dateOfBirth: dobFromGoogle || auth.dateOfBirth || "1996-08-15",
                avatar: auth.profileImageUrl || "",
                email: auth.email || "user@gmail.com",
                city: "New Delhi, India",
                birthTime: "10:30 AM"
            };
            return true;
        } catch {
            return false;
        }
    }

    async function fetchGoogleBirthday() {
        try {
            const response = await fetch("/api/auth/google-birthday");
            if (!response.ok) return null;
            const payload = await response.json();
            return payload?.birthDate ? String(payload.birthDate).slice(0, 10) : null;
        } catch {
            return null;
        }
    }

    function showGate() {
        ui.loginGate.classList.remove("hidden");
        ui.appShell.classList.add("hidden");
    }

    function showApp() {
        ui.loginGate.classList.add("hidden");
        ui.appShell.classList.remove("hidden");
    }

    async function renderReport() {
        const dob = new Date(state.profile.dateOfBirth);
        const zodiac = zodiacFromDate(state.profile.dateOfBirth);
        const moon = moonSignFromDate(state.profile.dateOfBirth);
        const asc = ascendantFromDate(state.profile.dateOfBirth);
        const lucky = luckyEssentialsFromSign(zodiac);

        ui.welcomeTitle.textContent = `Hello, ${state.profile.name}! ✨`;
        ui.topUserName.textContent = state.profile.name;
        ui.topUserEmail.textContent = state.profile.email || "user@gmail.com";
        ui.heroLine.textContent = "Here is your personalized AI + Astrology insights report.";
        ui.dobBadge.textContent = formatDateLong(dob);
        ui.timeBadge.textContent = state.profile.birthTime;
        ui.cityBadge.textContent = state.profile.city;
        ui.sunSign.textContent = `${zodiac} ${symbolForSign(zodiac)}`;
        ui.moonSign.textContent = `${moon} ${symbolForSign(moon)}`;
        ui.ascSign.textContent = `${asc} ${symbolForSign(asc)}`;
        ui.cosmicSummary.textContent = buildSummary(zodiac);
        ui.luckyList.innerHTML = `
            <li>Lucky Color: ${escapeHtml(lucky.color)}</li>
            <li>Lucky Number: ${escapeHtml(lucky.number)}</li>
            <li>Lucky Day: ${escapeHtml(lucky.day)}</li>
            <li>Lucky Gem: ${escapeHtml(lucky.gem)}</li>
        `;

        if (state.profile.avatar) {
            ui.avatarImage.src = state.profile.avatar;
            ui.avatarImage.classList.remove("hidden");
            ui.avatarFallback.classList.add("hidden");
            ui.topUserImage.src = state.profile.avatar;
            ui.topUserImage.classList.remove("hidden");
            ui.topUserFallback.classList.add("hidden");
        } else {
            ui.avatarImage.classList.add("hidden");
            ui.avatarFallback.classList.remove("hidden");
            const two = initials(state.profile.name);
            ui.avatarFallback.textContent = two;
            ui.topUserImage.classList.add("hidden");
            ui.topUserFallback.classList.remove("hidden");
            ui.topUserFallback.textContent = two;
        }

        await fetchAndRenderFamous(state.profile.dateOfBirth);
    }

    async function fetchAndRenderFamous(dob) {
        try {
            const response = await fetch(`/api/insights/famous-by-birthday?dob=${encodeURIComponent(dob)}`);
            if (!response.ok) {
                renderFamous(fallbackFamous());
                return;
            }
            const payload = await response.json();
            if (!payload?.success || !Array.isArray(payload.people) || !payload.people.length) {
                renderFamous(fallbackFamous());
                return;
            }
            renderFamous(payload.people.slice(0, 8).map(person => ({
                name: person.name || "Famous Personality",
                summary: person.summary || "Shares your birthday cosmic energy.",
                imageUrl: safeImage(person.imageUrl),
                articleUrl: person.articleUrl || ""
            })));
        } catch {
            renderFamous(fallbackFamous());
        }
    }

    function renderFamous(items) {
        ui.famousGrid.innerHTML = items.map(item => `
            <article class="famous-card">
                <img src="${escapeHtml(item.imageUrl)}" alt="${escapeHtml(item.name)}" loading="lazy" />
                <div class="famous-body">
                    <h4>${escapeHtml(item.name)}</h4>
                    <p>${escapeHtml(item.summary)}</p>
                    ${item.articleUrl ? `<a href="${escapeHtml(item.articleUrl)}" target="_blank" rel="noreferrer noopener">View profile</a>` : ""}
                </div>
            </article>
        `).join("");
    }

    function fallbackFamous() {
        return [
            {
                name: "Maya Angelou",
                summary: "Poet and storyteller with timeless voice.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/0/09/Dr._Maya_Angelou.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Maya_Angelou"
            },
            {
                name: "Gal Gadot",
                summary: "Actor with powerful screen presence.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/e/eb/Gal_Gadot_2018.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Gal_Gadot"
            },
            {
                name: "Akon",
                summary: "Singer and producer known worldwide.",
                imageUrl: "https://upload.wikimedia.org/wikipedia/commons/5/5d/Akon_2009.jpg",
                articleUrl: "https://en.wikipedia.org/wiki/Akon"
            }
        ];
    }

    function zodiacFromDate(dateText) {
        const d = new Date(dateText);
        const m = d.getMonth() + 1;
        const day = d.getDate();
        if ((m === 3 && day >= 21) || (m === 4 && day <= 19)) return "Aries";
        if ((m === 4 && day >= 20) || (m === 5 && day <= 20)) return "Taurus";
        if ((m === 5 && day >= 21) || (m === 6 && day <= 20)) return "Gemini";
        if ((m === 6 && day >= 21) || (m === 7 && day <= 22)) return "Cancer";
        if ((m === 7 && day >= 23) || (m === 8 && day <= 22)) return "Leo";
        if ((m === 8 && day >= 23) || (m === 9 && day <= 22)) return "Virgo";
        if ((m === 9 && day >= 23) || (m === 10 && day <= 22)) return "Libra";
        if ((m === 10 && day >= 23) || (m === 11 && day <= 21)) return "Scorpio";
        if ((m === 11 && day >= 22) || (m === 12 && day <= 21)) return "Sagittarius";
        if ((m === 12 && day >= 22) || (m === 1 && day <= 19)) return "Capricorn";
        if ((m === 1 && day >= 20) || (m === 2 && day <= 18)) return "Aquarius";
        return "Pisces";
    }

    function moonSignFromDate(dateText) {
        const signs = ["Aries", "Taurus", "Gemini", "Cancer", "Leo", "Virgo", "Libra", "Scorpio", "Sagittarius", "Capricorn", "Aquarius", "Pisces"];
        const seed = new Date(dateText).getDate() % 12;
        return signs[seed];
    }

    function ascendantFromDate(dateText) {
        const signs = ["Virgo", "Leo", "Cancer", "Gemini", "Taurus", "Aries", "Pisces", "Aquarius", "Capricorn", "Sagittarius", "Scorpio", "Libra"];
        const seed = (new Date(dateText).getMonth() + new Date(dateText).getDate()) % 12;
        return signs[seed];
    }

    function symbolForSign(sign) {
        const map = {
            Aries: "♈", Taurus: "♉", Gemini: "♊", Cancer: "♋", Leo: "♌", Virgo: "♍",
            Libra: "♎", Scorpio: "♏", Sagittarius: "♐", Capricorn: "♑", Aquarius: "♒", Pisces: "♓"
        };
        return map[sign] || "✦";
    }

    function luckyEssentialsFromSign(sign) {
        const map = {
            Aries: { color: "Red", number: "1, 9", day: "Tuesday", gem: "Ruby" },
            Taurus: { color: "Green", number: "2, 6", day: "Friday", gem: "Emerald" },
            Gemini: { color: "Yellow", number: "5", day: "Wednesday", gem: "Topaz" },
            Cancer: { color: "Silver", number: "2, 7", day: "Monday", gem: "Pearl" },
            Leo: { color: "Gold", number: "1, 3, 9", day: "Sunday", gem: "Ruby" },
            Virgo: { color: "Olive", number: "5, 7", day: "Wednesday", gem: "Peridot" },
            Libra: { color: "Pink", number: "6, 8", day: "Friday", gem: "Opal" },
            Scorpio: { color: "Maroon", number: "9", day: "Tuesday", gem: "Garnet" },
            Sagittarius: { color: "Purple", number: "3, 12", day: "Thursday", gem: "Turquoise" },
            Capricorn: { color: "Navy", number: "8", day: "Saturday", gem: "Onyx" },
            Aquarius: { color: "Blue", number: "4, 11", day: "Saturday", gem: "Amethyst" },
            Pisces: { color: "Sea Green", number: "3, 7", day: "Thursday", gem: "Aquamarine" }
        };
        return map[sign] || map.Leo;
    }

    function buildSummary(sign) {
        return `You are a natural ${sign} leader with creative vision and deep empathy. You inspire people and love deeply.`;
    }

    function safeImage(url) {
        if (typeof url !== "string") {
            return "https://upload.wikimedia.org/wikipedia/commons/6/65/No-Image-Placeholder.svg";
        }
        if (url.startsWith("http://") || url.startsWith("https://")) {
            return url;
        }
        return "https://upload.wikimedia.org/wikipedia/commons/6/65/No-Image-Placeholder.svg";
    }

    function formatDateLong(date) {
        return date.toLocaleDateString("en-GB", {
            day: "2-digit",
            month: "long",
            year: "numeric"
        });
    }

    function initials(name) {
        return String(name).split(" ").map(x => x[0]).join("").slice(0, 2).toUpperCase();
    }

    function escapeHtml(text) {
        return String(text)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }
</script>

<style>
    :root {
        --bg-main: #040814;
        --bg-card: #0b1228;
        --line: rgba(123, 150, 255, 0.28);
        --text-main: #eef2ff;
        --text-soft: #b7c3e5;
        --accent: #6d5cff;
        --accent2: #1dd7ff;
        --chip: rgba(117, 140, 232, 0.2);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, "Segoe UI", sans-serif;
        color: var(--text-main);
        background:
            radial-gradient(circle at 18% 20%, rgba(74, 84, 210, 0.28), transparent 46%),
            radial-gradient(circle at 80% 0%, rgba(126, 35, 167, 0.28), transparent 44%),
            linear-gradient(180deg, #060a1b 0%, #02040c 100%);
        min-height: 100vh;
    }

    .hidden {
        display: none !important;
    }

    .login-gate {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 20px;
    }

    .login-panel {
        width: min(720px, 100%);
        background: rgba(8, 14, 33, 0.9);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 32px;
        text-align: center;
        box-shadow: 0 20px 60px rgba(22, 35, 87, 0.45);
    }

    .brand-kicker {
        margin: 0 0 12px;
        letter-spacing: 0.18em;
        font-size: 0.74rem;
        color: var(--accent2);
    }

    .login-panel h1 {
        margin: 0 0 12px;
        font-size: clamp(1.5rem, 4vw, 2.2rem);
    }

    .gate-note {
        margin: 0 0 18px;
        color: var(--text-soft);
    }

    .primary-btn,
    .ghost-btn {
        border: none;
        border-radius: 999px;
        padding: 10px 16px;
        font-weight: 700;
        cursor: pointer;
        color: #fff;
    }

    .primary-btn {
        background: linear-gradient(135deg, #6e63ff, #5ad0ff);
        box-shadow: 0 8px 24px rgba(66, 135, 255, 0.35);
    }

    .ghost-btn {
        background: rgba(140, 157, 255, 0.12);
        border: 1px solid rgba(131, 155, 255, 0.3);
    }

    .astro-shell {
        max-width: 1400px;
        margin: 0 auto;
        padding: 14px 14px 28px;
        display: grid;
        gap: 12px;
    }

    .topbar {
        background: rgba(8, 14, 33, 0.78);
        border: 1px solid var(--line);
        border-radius: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        backdrop-filter: blur(8px);
    }

    .logo-block {
        display: flex;
