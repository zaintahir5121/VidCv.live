        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .insight-card {
        border-radius: 18px;
        border: 1px solid var(--line);
        padding: 12px;
        background: #fff;
    }

    .insight-card h4 {
        margin: 0 0 8px;
        font-size: 0.95rem;
    }

    .insight-card p {
        margin: 0;
        color: #59608a;
    }

    .share-preview {
        border-radius: 18px;
        padding: 18px;
        color: #fff;
        background: linear-gradient(135deg, #5c46ff, #f466a0);
        font-weight: 600;
        line-height: 1.5;
        margin-bottom: 12px;
    }

    .share-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .share-actions .cta-btn.primary {
        background: #4e43f7;
        color: #fff;
    }

    .share-actions .cta-btn.ghost {
        border: 1px solid #cfd6ff;
