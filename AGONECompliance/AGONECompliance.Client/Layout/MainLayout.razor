@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="header-block">
                <div class="header-title">AGONECompliance</div>
                <div class="header-subtitle">Evaluation Workspace Portal</div>
            </div>
            <div class="header-actions">
                <a class="btn btn-sm btn-light" href="/">Dashboard</a>
                <a class="btn btn-sm btn-light" href="/jobs">Jobs</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="portal-footer px-4">
            <span>@DateTime.Now.Year AGONECompliance</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
