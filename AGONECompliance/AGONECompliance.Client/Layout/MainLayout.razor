@inherits LayoutComponentBase
@using AGONECompliance.Client.Services
@inject AuthState Auth

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div>
                <div class="header-title">AGONECompliance</div>
            </div>
            <div class="header-user">
                <div class="user-avatar">@Auth.Initials</div>
                <div class="user-meta">
                    <strong>@Auth.DisplayName</strong>
                    <small>@Auth.Email</small>
                </div>
                <button class="btn btn-sm btn-light" @onclick="Logout">Logout</button>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="portal-footer px-4">
            <span>@DateTime.Now.Year AGONECompliance</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private void Logout()
    {
        Auth.Logout();
    }
}
