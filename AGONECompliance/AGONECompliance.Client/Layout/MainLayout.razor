@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="header-title">AGONECompliance Portal</div>
            <div class="header-subtitle">Evaluation Workspace cockpit · Guide + Appendix + Prospectus validation</div>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="portal-footer px-4">
            <span>AGONECompliance · Demo-ready compliance automation on Azure</span>
        </footer>
    </main>
</div>

