@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="header-block">
                <img class="header-logo" src="/brand/ag-one-compliance-logo.svg" alt="AG ONE Compliance" />
                <div>
                    <div class="header-title">AG ONE Compliance</div>
                    <div class="header-subtext">Evaluation Workspace Portal</div>
                </div>
            </div>
            <div class="header-actions">
                <a class="btn btn-sm btn-light" href="/">Dashboard</a>
                <a class="btn btn-sm btn-light" href="/jobs">Jobs</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="portal-footer px-4">
            <span class="footer-brand">@DateTime.Now.Year AG ONE Compliance</span>
            <span class="footer-meta">Guide + Appendix + Prospectus evaluation platform</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
