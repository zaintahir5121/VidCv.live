@page "/background-jobs"
@attribute [StreamRendering]
@using AGONECompliance.Client.Services
@inject PortalContext Portal

<PageTitle>Background Jobs - AGONECompliance</PageTitle>

<section class="module-card">
    <h2>Background Jobs Monitor</h2>
    <p class="module-subtitle">Track document upload parsing and evaluation workers running in Quartz background queues.</p>
    <div class="row-actions">
        <button class="btn btn-gradient" @onclick="RefreshAsync" disabled="@Portal.IsBusy">Refresh</button>
        <span class="small-muted">@lastRefreshLabel</span>
    </div>
    <div class="status-banner">@Portal.StatusMessage</div>
</section>

<section class="module-card">
    <h2>Processing Queue</h2>
    <div class="table-wrap">
        <table class="table result-table">
            <thead>
            <tr>
                <th>Job Id</th>
                <th>Workspace</th>
                <th>Type</th>
                <th>Status</th>
                <th>Document</th>
                <th>Run</th>
                <th>Created</th>
                <th>Completed</th>
                <th>Failure</th>
            </tr>
            </thead>
            <tbody>
            @if (Portal.State.BackgroundJobs.Count == 0)
            {
                <tr><td colspan="9">No background jobs yet.</td></tr>
            }
            else
            {
                @foreach (var job in Portal.State.BackgroundJobs.OrderByDescending(x => x.CreatedAtUtc))
                {
                    <tr>
                        <td><strong>@job.Id.ToString("N")[..8]</strong></td>
                        <td>@((job.EvaluationWorkspaceId?.ToString("N")[..8]) ?? "-")</td>
                        <td>@job.JobType</td>
                        <td><span class="@($"pill {GetStatusClass(job.Status)}")">@job.Status</span></td>
                        <td>@(job.RelatedDocumentId?.ToString("N")[..8] ?? "-")</td>
                        <td>@(job.RelatedEvaluationRunId?.ToString("N")[..8] ?? "-")</td>
                        <td>@job.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(job.CompletedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(job.FailureReason) ? "-" : job.FailureReason)</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@code {
    private string lastRefreshLabel = "Not refreshed yet.";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        await Portal.RefreshAllAsync();
        lastRefreshLabel = $"Last refresh: {DateTimeOffset.Now:yyyy-MM-dd HH:mm:ss}";
    }

    private static string GetStatusClass(string status) => status.ToLowerInvariant() switch
    {
        "completed" => "pill-ok",
        "failed" => "pill-bad",
        "running" => "pill-warning",
        "processing" => "pill-warning",
        "queued" => "pill-neutral",
        _ => "pill-neutral"
    };
}
