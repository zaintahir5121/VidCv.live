@page "/prompts"
@attribute [StreamRendering]
@using AGONECompliance.Client.Services
@using AGONECompliance.Shared
@inject PortalContext Portal

<PageTitle>Prompts - AGONECompliance</PageTitle>

<section class="module-card">
    <h2>Prompt Template Management</h2>
    <p class="module-subtitle">Stored prompts for rule extraction and prospectus evaluation (editable and versioned in DB).</p>
    <div class="status-banner">@Portal.StatusMessage</div>
</section>

<section class="module-card">
    @if (Portal.State.PromptTemplates.Count == 0)
    {
        <p>No prompt templates available.</p>
    }
    else
    {
        <PaginationBar CurrentPage="@promptsPage"
                       TotalPages="@promptsTotalPages"
                       TotalItems="@sortedPrompts.Count"
                       PageSize="@PageSize"
                       Label="Prompt templates"
                       OnPrevious="PreviousPromptsPage"
                       OnNext="NextPromptsPage" />
        @foreach (var item in PagedPrompts)
        {
            <div class="prompt-card">
                <div class="run-head">
                    <strong>@item.TemplateType (v@item.Version)</strong>
                    <span class="@($"pill {(item.IsActive ? "pill-ok" : "pill-warning")}")">@(item.IsActive ? "Active" : "Inactive")</span>
                </div>

                <div class="form-grid">
                    <input class="form-control" @bind="item.Name" />
                    <input class="form-control" @bind="item.Description" />
                    <label class="check-line"><input type="checkbox" @bind="item.IsActive" /> Active</label>
                    <textarea class="form-control area" @bind="item.SystemPrompt"></textarea>
                    <textarea class="form-control area" @bind="item.UserPromptFormat"></textarea>
                </div>

                <button class="btn btn-light" @onclick="() => Portal.SavePromptAsync(item)">Save Template</button>
            </div>
        }
    }
</section>

@code {
    private const int PageSize = 10;
    private int promptsPage = 1;
    private List<PromptTemplateDto> sortedPrompts = [];
    private int promptsTotalPages => Math.Max(1, (int)Math.Ceiling(sortedPrompts.Count / (double)PageSize));
    private IEnumerable<PromptTemplateDto> PagedPrompts =>
        sortedPrompts.Skip((promptsPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        await Portal.RefreshAllAsync();
        RefreshPromptsPagination();
    }

    private void RefreshPromptsPagination()
    {
        sortedPrompts = Portal.State.PromptTemplates
            .OrderBy(x => x.TemplateType)
            .ThenByDescending(x => x.Version)
            .ToList();
        promptsPage = Math.Clamp(promptsPage, 1, promptsTotalPages);
    }

    private Task PreviousPromptsPage()
    {
        if (promptsPage > 1)
        {
            promptsPage--;
        }

        return Task.CompletedTask;
    }

    private Task NextPromptsPage()
    {
        if (promptsPage < promptsTotalPages)
        {
            promptsPage++;
        }

        return Task.CompletedTask;
    }
}
