@page "/login"
@attribute [StreamRendering]
@using AGONECompliance.Client.Services
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Login - AGONECompliance</PageTitle>

<section class="module-card login-card">
    <h2>Sign in</h2>
    <p class="module-subtitle">Use your evaluator account to access compliance workspaces.</p>

    <div class="form-grid">
        <input class="form-control" placeholder="Email" @bind="email" />
        <input class="form-control" type="password" placeholder="Password" @bind="password" />
        <button class="btn btn-gradient" @onclick="LoginAsync">Login</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="status-banner">@errorMessage</div>
    }
</section>

@code {
    private string email = "admin@agone.com";
    private string password = "admin123";
    private string errorMessage = string.Empty;

    private void LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Email and password are required.";
            return;
        }

        var success = Auth.Login(email, password);
        if (!success)
        {
            errorMessage = "Invalid login details.";
            return;
        }

        Nav.NavigateTo("/", forceLoad: false);
    }
}
