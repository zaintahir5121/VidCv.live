@page "/documents"
@attribute [StreamRendering]
@using AGONECompliance.Client.Services
@using AGONECompliance.Shared
@inject PortalContext Portal

<PageTitle>Documents - AGONECompliance</PageTitle>

<section class="module-card">
    <div class="section-head">
        <div>
            <h2>Document Intake</h2>
            <p class="module-subtitle">Upload PDF-only Guide, Appendix, and Prospectus files (up to 500 MB each). Scanned/image PDFs are extracted through Azure Document Intelligence OCR.</p>
        </div>
        <span class="soft-chip">Step 1 of 3</span>
    </div>
    @if (Portal.State.SelectedEvaluationWorkspaceId is null)
    {
        <div class="status-banner">Select or create an Evaluation Workspace on the Dashboard first.</div>
    }

    <div class="upload-grid flow-card-grid">
        <div class="upload-block flow-card">
            <label>Guide Document</label>
            <p class="small-muted">Primary standards and requirements source.</p>
            <InputFile accept=".pdf,application/pdf"
                       @key="@($"guide-{inputKey}")"
                       OnChange="@(args => UploadAsync(DocumentType.Guide, args))" />
        </div>
        <div class="upload-block flow-card">
            <label>Appendix Document</label>
            <p class="small-muted">Supplementary checks and annex obligations.</p>
            <InputFile accept=".pdf,application/pdf"
                       @key="@($"appendix-{inputKey}")"
                       OnChange="@(args => UploadAsync(DocumentType.Appendix, args))" />
        </div>
        <div class="upload-block flow-card">
            <label>Prospectus Document</label>
            <p class="small-muted">Target document to validate for compliance.</p>
            <InputFile accept=".pdf,application/pdf"
                       @key="@($"prospectus-{inputKey}")"
                       OnChange="@(args => UploadAsync(DocumentType.Prospectus, args))" />
        </div>
    </div>

    <div class="status-banner">@Portal.StatusMessage</div>
</section>

<section class="module-card">
    <h2>Uploaded Documents</h2>
    <PaginationBar CurrentPage="@documentsPage"
                   TotalPages="@documentsTotalPages"
                   TotalItems="@sortedDocuments.Count"
                   PageSize="@PageSize"
                   Label="Documents"
                   OnPrevious="PreviousDocumentsPage"
                   OnNext="NextDocumentsPage" />
    <div class="table-wrap">
        <table class="table doc-table">
            <thead>
            <tr>
                <th>Type</th>
                <th>File Name</th>
                <th>Content Type</th>
                <th>Size (KB)</th>
                <th>Uploaded</th>
                <th>Processed</th>
                <th>Preview</th>
            </tr>
            </thead>
            <tbody>
            @if (Portal.State.Documents.Count == 0)
            {
                <tr><td colspan="7">No files uploaded yet.</td></tr>
            }
            else
            {
                @foreach (var item in PagedDocuments)
                {
                    <tr>
                        <td>@item.Type</td>
                        <td>@item.OriginalFileName</td>
                        <td>@item.ContentType</td>
                        <td>@Math.Round(item.SizeBytes / 1024.0, 1)</td>
                        <td>@item.UploadedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(item.IsProcessed ? "Yes" : "No")</td>
                        <td><a href="@($"api/documents/{item.Id}/content")" target="_blank">Open</a></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@code {
    private int inputKey;
    private const int PageSize = 10;
    private int documentsPage = 1;
    private List<DocumentDto> sortedDocuments = [];
    private int documentsTotalPages => Math.Max(1, (int)Math.Ceiling(sortedDocuments.Count / (double)PageSize));
    private IEnumerable<DocumentDto> PagedDocuments =>
        sortedDocuments.Skip((documentsPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        await Portal.RefreshAllAsync();
        RefreshDocumentPagination();
    }

    private async Task UploadAsync(DocumentType type, InputFileChangeEventArgs args)
    {
        if (args.File is null)
        {
            return;
        }

        await Portal.UploadDocumentAsync(type, args.File);
        inputKey++;
        RefreshDocumentPagination();
    }

    private void RefreshDocumentPagination()
    {
        sortedDocuments = Portal.State.Documents
            .OrderByDescending(x => x.UploadedAtUtc)
            .ToList();
        documentsPage = Math.Clamp(documentsPage, 1, documentsTotalPages);
    }

    private Task PreviousDocumentsPage()
    {
        if (documentsPage > 1)
        {
            documentsPage--;
        }

        return Task.CompletedTask;
    }

    private Task NextDocumentsPage()
    {
        if (documentsPage < documentsTotalPages)
        {
            documentsPage++;
        }

        return Task.CompletedTask;
    }
}
