@page "/evaluations"
@attribute [StreamRendering]
@using System.Text.RegularExpressions
@using AGONECompliance.Client.Services
@using AGONECompliance.Shared
@inject PortalContext Portal
@inject ApiClient Api

<PageTitle>Evaluations - AGONECompliance</PageTitle>

<section class="page-hero">
    <h1>Evaluations</h1>
    <p>Launch validation runs, inspect outcomes, and export formal PDF reports.</p>
</section>

<section class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-label">Total Runs</div>
        <div class="kpi-value">@Portal.State.Runs.Count</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Completed</div>
        <div class="kpi-value">@Portal.State.Runs.Count(x => x.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Failed</div>
        <div class="kpi-value">@Portal.State.Runs.Count(x => x.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase))</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Checks Selected</div>
        <div class="kpi-value">@Portal.State.SelectedRuleIds.Count</div>
    </div>
</section>

<section class="module-card">
    <h2>Start New Evaluation</h2>
    <p class="module-subtitle">Step 1: choose a prospectus. Step 2: pick checks. Step 3: run evaluation.</p>
    @if (Portal.State.SelectedEvaluationWorkspaceId is null)
    {
        <div class="status-banner">Select or create an Evaluation Workspace on the Dashboard first.</div>
    }
    <div class="workspace-context run-toolbar">
        <span class="pill pill-neutral">Selected checks</span>
        <strong>@Portal.State.SelectedRuleIds.Count</strong>
        <span class="small-muted">Choose active checks below before starting.</span>
        <span class="pill pill-neutral">Prospectus</span>
        <strong>@(Portal.State.SelectedProspectusDocumentId is null ? "Not selected" : "Selected")</strong>
    </div>
    <div class="row-actions compact-actions">
        <select class="form-select select-input" @bind="Portal.State.SelectedProspectusDocumentId">
            <option value="">Select prospectus document</option>
            @foreach (var item in Portal.State.Documents.Where(x => x.Type == DocumentType.Prospectus))
            {
                <option value="@item.Id">@item.OriginalFileName (@(Math.Round(item.SizeBytes / 1024.0, 1)) KB)</option>
            }
        </select>
        <button class="btn btn-light" @onclick="Portal.SelectAllRules">Select All Checks</button>
        <button class="btn btn-light" @onclick="Portal.ClearRuleSelection">Clear Checks</button>
        <button class="btn btn-gradient"
                @onclick="StartEvaluationAsync"
                disabled="@(Portal.State.SelectedEvaluationWorkspaceId is null || Portal.IsBusy || Portal.State.SelectedProspectusDocumentId is null || Portal.State.SelectedRuleIds.Count == 0)">
            Start Evaluation
        </button>
    </div>
    <div class="status-banner">@Portal.StatusMessage</div>
</section>

<section class="module-card">
    <h2>Step 2: Choose Checks</h2>
    <PaginationBar CurrentPage="@checksPage"
                   TotalPages="@checksTotalPages"
                   TotalItems="@activeRules.Count"
                   PageSize="@PageSize"
                   Label="Checks"
                   OnPrevious="PreviousChecksPage"
                   OnNext="NextChecksPage" />
    <div class="table-wrap">
        <table class="table rule-table">
            <thead>
            <tr>
                <th>Select</th>
                <th>Code</th>
                <th>Category</th>
                <th>Action Party</th>
                <th>Reference</th>
                <th>Requirement</th>
            </tr>
            </thead>
            <tbody>
            @if (Portal.State.Rules.Count == 0)
            {
                <tr><td colspan="6">No rules available. Generate rules first.</td></tr>
            }
            else
            {
                @foreach (var rule in PagedActiveRules)
                {
                    <tr>
                        <td>
                            <input type="checkbox"
                                   checked="@Portal.State.SelectedRuleIds.Contains(rule.Id)"
                                   @onchange="@((ChangeEventArgs e) => Portal.ToggleRuleSelection(rule.Id, e.Value as bool? == true))" />
                        </td>
                        <td>
                            <strong>@rule.Code</strong>
                            <div class="small-muted">@rule.Title</div>
                        </td>
                        <td><span class="@($"pill {GetCategoryClass(rule.ClassificationCategory)}")">@rule.ClassificationCategory</span></td>
                        <td><span class="@($"pill {GetActionPartyClass(rule.ActionParty)}")">@rule.ActionParty</span></td>
                        <td>@rule.Reference</td>
                        <td>@rule.RequirementText</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

<section class="module-card">
    <div class="module-header-row">
        <h2>Evaluation Runs</h2>
        <a class="btn btn-light" href="/jobs">Open Jobs Monitoring</a>
    </div>
    <PaginationBar CurrentPage="@runsPage"
                   TotalPages="@runsTotalPages"
                   TotalItems="@sortedRuns.Count"
                   PageSize="@PageSize"
                   Label="Runs"
                   OnPrevious="PreviousRunsPage"
                   OnNext="NextRunsPage" />
    @if (Portal.State.Runs.Count == 0)
    {
        <p class="empty-state">No runs yet. Start your first evaluation above.</p>
    }
    else
    {
        @foreach (var run in PagedRuns)
        {
            <div class="run-card">
                <div class="run-head">
                    <div>
                        <strong>Run @run.Id.ToString("N")[..8]</strong>
                        <div class="small-muted">@run.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </div>
                    <span class="@($"pill {GetStatusClass(run.Status)}")">@run.Status</span>
                </div>
                <div class="row-actions">
                    <a class="btn btn-light" href="@($"/evaluations/{run.Id}")">Open Full Listing</a>
                    <a class="btn btn-light" href="@PdfUrl(run.Id)" target="_blank">Export PDF</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(run.FailureReason))
                {
                    <p class="error-text">Failure: @run.FailureReason</p>
                }

                @if (run.Results.Count > 0)
                {
                    <PaginationBar CurrentPage="@GetResultPage(run.Id)"
                                   TotalPages="@GetResultTotalPages(run.Id)"
                                   TotalItems="@run.Results.Count"
                                   PageSize="@PageSize"
                                   Label="@($"Results for {run.Id.ToString("N")[..8]}")"
                                   OnPrevious="@(() => PreviousRunResultPage(run.Id))"
                                   OnNext="@(() => NextRunResultPage(run.Id))" />
                    <div class="table-wrap">
                        <table class="table result-table">
                            <thead>
                            <tr>
                                <th>Rule</th>
                                <th>Category</th>
                                <th>Action Party</th>
                                <th>Guide Ref</th>
                                <th>Status</th>
                                <th>Confidence</th>
                                <th>Reason</th>
                                <th>Evidence Location</th>
                                <th>Evidence / PDF Link</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var result in GetPagedResults(run))
                            {
                                <tr>
                                    <td>
                                        <strong>@result.RuleCode</strong>
                                        <div class="small-muted">@result.RuleTitle</div>
                                    </td>
                                    <td>@result.RuleCategory</td>
                                    <td>@result.RuleActionParty</td>
                                    <td>
                                        <div class="guide-reference-inline">@PrimaryGuideReference(result.GuideReference)</div>
                                        @if (HasGuideContext(result.GuideReference))
                                        {
                                            <details class="guide-context">
                                                <summary>Guide Context Used</summary>
                                                <div class="guide-context-content">@ExtractGuideContext(result.GuideReference)</div>
                                            </details>
                                        }
                                    </td>
                                    <td><span class="@($"pill {GetResultClass(result.Status)}")">@result.Status</span></td>
                                    <td>@(Math.Round(result.ConfidenceScore * 100, 1))%</td>
                                    <td>@result.Reason</td>
                                    <td>@result.EvidenceLocation</td>
                                    <td>
                                        <div>@result.EvidenceExcerpt</div>
                                        <div class="row-actions" style="margin-top:0.35rem;">
                                            <button class="btn btn-light btn-sm"
                                                    @onclick="@(() => OpenEvidencePopupAsync(run.ProspectusDocumentId, result))">
                                                View evidence popup
                                            </button>
                                            @if (!string.IsNullOrWhiteSpace(result.EvidenceLink))
                                            {
                                                <a href="@result.EvidenceLink" target="_blank">
                                                    Open matched location
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
</section>

@if (isEvidencePopupOpen)
{
    <div class="evidence-modal-backdrop" @onclick="CloseEvidencePopup">
        <div class="evidence-modal" @onclick:stopPropagation="true">
            <div class="evidence-modal-head">
                <h3>Prospectus Evidence Viewer</h3>
                <button class="btn btn-light btn-sm" @onclick="CloseEvidencePopup">Close</button>
            </div>
            @if (isEvidencePopupLoading)
            {
                <p>Loading evidence...</p>
            }
            else if (!string.IsNullOrWhiteSpace(evidencePopupError))
            {
                <p class="error-text">@evidencePopupError</p>
            }
            else if (selectedEvidence is not null)
            {
                <div class="evidence-modal-body">
                    <div class="small-muted"><strong>Page:</strong> @selectedEvidence.PageNumber</div>
                    <div class="small-muted"><strong>File:</strong> @selectedEvidence.OriginalFileName</div>
                    <div class="row-actions" style="margin:0.45rem 0;">
                        <a class="btn btn-light btn-sm" href="@selectedEvidence.PdfPageLink" target="_blank">Open exact PDF page</a>
                    </div>
                    <div class="evidence-text-box">@selectedEvidence.ExtractedText</div>
                </div>
            }
        </div>
    </div>
}

@if (Portal.LatestReport is not null)
{
    <section class="module-card">
        <h2>Latest Compliance Report</h2>
        <p class="module-subtitle">
            Total: @Portal.LatestReport.TotalRules · Compliant: @Portal.LatestReport.CompliantCount ·
            Non-Compliant: @Portal.LatestReport.NonCompliantCount · Needs Review: @Portal.LatestReport.NeedsReviewCount
        </p>
        <div class="status-banner">
            Report maps each guide rule reference to specific evidence location in the selected prospectus.
        </div>
    </section>
}

@code {
    private const int PageSize = 10;
    private int checksPage = 1;
    private int runsPage = 1;
    private List<ComplianceRuleDto> activeRules = [];
    private List<EvaluationRunDto> sortedRuns = [];
    private readonly Dictionary<Guid, int> runResultPages = new();
    private bool isEvidencePopupOpen;
    private bool isEvidencePopupLoading;
    private string? evidencePopupError;
    private DocumentPageEvidenceDto? selectedEvidence;
    private int checksTotalPages => Math.Max(1, (int)Math.Ceiling(activeRules.Count / (double)PageSize));
    private int runsTotalPages => Math.Max(1, (int)Math.Ceiling(sortedRuns.Count / (double)PageSize));
    private IEnumerable<ComplianceRuleDto> PagedActiveRules =>
        activeRules.Skip((checksPage - 1) * PageSize).Take(PageSize);
    private IEnumerable<EvaluationRunDto> PagedRuns =>
        sortedRuns.Skip((runsPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        await Portal.RefreshAllAsync();
        RefreshPaginationState();
    }

    private async Task StartEvaluationAsync()
    {
        await Portal.StartEvaluationAsync();
        RefreshPaginationState();
    }

    private async Task OpenEvidencePopupAsync(Guid documentId, EvaluationResultItemDto result)
    {
        isEvidencePopupOpen = true;
        isEvidencePopupLoading = true;
        evidencePopupError = null;
        selectedEvidence = null;

        var pageNumber = result.PageNumber ?? ExtractPageFromEvidenceLocation(result.EvidenceLocation) ?? 1;
        try
        {
            selectedEvidence = await Api.GetDocumentPageEvidenceAsync(documentId, pageNumber);
            if (selectedEvidence is null)
            {
                evidencePopupError = "No evidence page data found.";
            }
        }
        catch (Exception ex)
        {
            evidencePopupError = ex.Message;
        }
        finally
        {
            isEvidencePopupLoading = false;
        }
    }

    private void CloseEvidencePopup()
    {
        isEvidencePopupOpen = false;
        isEvidencePopupLoading = false;
        evidencePopupError = null;
        selectedEvidence = null;
    }

    private static int? ExtractPageFromEvidenceLocation(string? location)
    {
        if (string.IsNullOrWhiteSpace(location))
        {
            return null;
        }

        var match = Regex.Match(location, @"\bpage\s*(\d+)\b", RegexOptions.IgnoreCase);
        return match.Success && int.TryParse(match.Groups[1].Value, out var page) ? page : null;
    }

    private void RefreshPaginationState()
    {
        activeRules = Portal.State.Rules
            .Where(x => x.IsActive)
            .OrderBy(x => x.Code)
            .ToList();
        sortedRuns = Portal.State.Runs
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToList();

        checksPage = Math.Clamp(checksPage, 1, checksTotalPages);
        runsPage = Math.Clamp(runsPage, 1, runsTotalPages);

        foreach (var run in sortedRuns)
        {
            if (!runResultPages.ContainsKey(run.Id))
            {
                runResultPages[run.Id] = 1;
            }

            runResultPages[run.Id] = Math.Clamp(runResultPages[run.Id], 1, GetResultTotalPages(run.Id));
        }
    }

    private string PdfUrl(Guid runId)
    {
        if (Portal.State.SelectedEvaluationWorkspaceId is null)
        {
            return "#";
        }

        return $"api/evaluations/{runId}/report/pdf?evaluationWorkspaceId={Portal.State.SelectedEvaluationWorkspaceId.Value}";
    }

    private Task PreviousChecksPage()
    {
        if (checksPage > 1)
        {
            checksPage--;
        }

        return Task.CompletedTask;
    }

    private Task NextChecksPage()
    {
        if (checksPage < checksTotalPages)
        {
            checksPage++;
        }

        return Task.CompletedTask;
    }

    private Task PreviousRunsPage()
    {
        if (runsPage > 1)
        {
            runsPage--;
        }

        return Task.CompletedTask;
    }

    private Task NextRunsPage()
    {
        if (runsPage < runsTotalPages)
        {
            runsPage++;
        }

        return Task.CompletedTask;
    }

    private int GetResultPage(Guid runId)
    {
        if (!runResultPages.TryGetValue(runId, out var page))
        {
            page = 1;
            runResultPages[runId] = page;
        }

        return page;
    }

    private int GetResultTotalPages(Guid runId)
    {
        var run = sortedRuns.FirstOrDefault(x => x.Id == runId);
        if (run is null || run.Results.Count == 0)
        {
            return 1;
        }

        return Math.Max(1, (int)Math.Ceiling(run.Results.Count / (double)PageSize));
    }

    private IEnumerable<EvaluationResultItemDto> GetPagedResults(EvaluationRunDto run)
    {
        var page = GetResultPage(run.Id);
        return run.Results
            .Skip((page - 1) * PageSize)
            .Take(PageSize);
    }

    private Task PreviousRunResultPage(Guid runId)
    {
        var page = GetResultPage(runId);
        if (page > 1)
        {
            runResultPages[runId] = page - 1;
        }

        return Task.CompletedTask;
    }

    private Task NextRunResultPage(Guid runId)
    {
        var page = GetResultPage(runId);
        var totalPages = GetResultTotalPages(runId);
        if (page < totalPages)
        {
            runResultPages[runId] = page + 1;
        }

        return Task.CompletedTask;
    }

    private static string GetStatusClass(string status) => status.ToLowerInvariant() switch
    {
        "completed" => "pill-ok",
        "failed" => "pill-bad",
        "processing" => "pill-warning",
        _ => "pill-neutral"
    };

    private static string GetResultClass(ComplianceStatus status) => status switch
    {
        ComplianceStatus.Compliant => "pill-ok",
        ComplianceStatus.NonCompliant => "pill-bad",
        ComplianceStatus.NeedsReview => "pill-warning",
        _ => "pill-neutral"
    };

    private static string GetCategoryClass(string category)
    {
        return category.ToLowerInvariant() switch
        {
            "requirement" => "pill-ok",
            "info" => "pill-warning",
            _ => "pill-neutral"
        };
    }

    private static string GetActionPartyClass(string actionParty)
    {
        return actionParty.ToLowerInvariant() switch
        {
            "onsite" => "pill-ok",
            "management" => "pill-warning",
            "none" => "pill-neutral",
            _ => "pill-neutral"
        };
    }

    private static bool HasGuideContext(string? guideReference)
        => !string.IsNullOrWhiteSpace(ExtractGuideContext(guideReference));

    private static string PrimaryGuideReference(string? guideReference)
    {
        if (string.IsNullOrWhiteSpace(guideReference))
        {
            return "-";
        }

        var contextMarker = " | Context:";
        var markerIndex = guideReference.IndexOf(contextMarker, StringComparison.OrdinalIgnoreCase);
        if (markerIndex < 0)
        {
            return guideReference;
        }

        return guideReference[..markerIndex].Trim();
    }

    private static string ExtractGuideContext(string? guideReference)
    {
        if (string.IsNullOrWhiteSpace(guideReference))
        {
            return string.Empty;
        }

        var contextMarker = " | Context:";
        var markerIndex = guideReference.IndexOf(contextMarker, StringComparison.OrdinalIgnoreCase);
        if (markerIndex < 0)
        {
            return string.Empty;
        }

        return guideReference[(markerIndex + contextMarker.Length)..].Trim();
    }
}
